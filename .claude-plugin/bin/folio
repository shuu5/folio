#!/usr/bin/env bash
# folio CLI (Phase X3 試作)
# 完成形は init / validate / inventory / prime / fix subcommands (ADR-0003 §2.1)
# 試作段階は version / help / init / inventory / prime / validate を実装
#
# inventory subcommand (REQ-VER-010):
#   relations.html §4.4.1 の scan 対象 (architecture/spec/ + architecture/decisions/ +
#   architecture/research/ の <head> JSON-LD を持つ .html) を走査し、 §4.1 schema 準拠の
#   inventory.json を生成する (走査 base = architecture/、 出力先 = repo-root を decouple)。
#   constitution.html は spec graph の対象外 (不変 framework anchor、 FolioConstitution schema =
#   spec の @context-object+@id 規約と別形) のため scan から除外する (X4-C / ADR-0023)。
#   cwd = repo root 前提 (REQ-VER-011 「at repo root」)。
#   依存: jq / grep -P / awk / realpath / date (python 等の追加 runtime 依存なし、
#   既存 plugin (bin/folio / runner.sh / *.sh) の bash idiom に統一)。

set -uo pipefail

VERSION="0.4.2-draft"

# ============================================================================
# inventory helpers — HTML spec から field 抽出 (folio 自身の整った spec 群が対象)
# ============================================================================

# <head> 内の最初の application/ld+json ブロック本文を stdout に返す (無ければ空)。
# </head> 到達で打ち切るため body 中の (エスケープされた) 言及には反応しない:
#   prose の `&lt;script type="application/ld+json"&gt;` は `<script` に一致しないので除外。
folio_extract_head_jsonld() {
  awk '
    /<\/head>/ { exit }
    capturing && /<\/script>/ { exit }
    capturing { print }
    /<script[^>]*type="application\/ld\+json"/ { capturing = 1 }
  ' "$1"
}

# <meta name="$2" content="..."> の content を stdout に返す (無ければ空文字)。
folio_extract_meta() {
  grep -oP "<meta name=\"$2\" content=\"\K[^\"]*" "$1" 2>/dev/null | head -1
}

# <title>...</title> の text を stdout に返す。
folio_extract_title() {
  grep -oP '<title>\K[^<]*' "$1" 2>/dev/null | head -1
}

# <header> .meta div の最終 &middot; セグメントを summary として返す
# (§4.1 source: spec <header> .meta)。 HTML entity を最小 decode + trim。
folio_extract_summary() {
  local meta seg
  meta=$(grep -oP '<div class="meta">\K[^<]*' "$1" 2>/dev/null | head -1)
  [[ -z "$meta" ]] && return 0
  seg="$meta"
  [[ "$meta" == *"&middot;"* ]] && seg="${meta##*&middot;}"
  # trim 前後 whitespace
  seg="${seg#"${seg%%[![:space:]]*}"}"
  seg="${seg%"${seg##*[![:space:]]}"}"
  printf '%s' "$seg" | sed -e 's/&amp;/\&/g; s/&lt;/</g; s/&gt;/>/g; s/&quot;/"/g; s/&#39;/'"'"'/g; s/&middot;/·/g'
}

# 相対 @id ($1) を、 その spec が属する subdir ($2) 起点で解決し architecture ($3) 相対へ
# 正規化して返す。 #anchor は保持。 例 (subdir=spec):
#   ./rules.html#s4-format        -> spec/rules.html#s4-format
#   ./constitution.html           -> spec/constitution.html
#   ../research/foo.html          -> research/foo.html
folio_resolve_relpath() {
  local rawid="$1" subdir="$2" arch_abs="$3" pathpart anchor resolved
  if [[ "$rawid" == *"#"* ]]; then
    pathpart="${rawid%%#*}"
    anchor="#${rawid#*#}"
  else
    pathpart="$rawid"
    anchor=""
  fi
  resolved=$(realpath -m --relative-to="$arch_abs" "${arch_abs}/${subdir}/${pathpart}")
  printf '%s%s' "$resolved" "$anchor"
}

# JSON-LD block ($1) から relation を集約した object を返す (§4.1 specs[].relations)。
# relation = 値が [{ "@id": ... }, ...] 形式の dc:* / folio:* 等のプロパティ
# (dc:title=string / folio:version=string / folio:stakeholders=[string] は形が違うので自動除外)。
# 各 @id は subdir ($2) 起点で architecture ($3) 相対へ正規化。 無ければ "{}"。
folio_build_relations() {
  local block="$1" subdir="$2" arch_abs="$3" pairs lines k rawid res
  pairs=$(printf '%s' "$block" | jq -r '
    to_entries[]
    | select(.value | type == "array")
    | select(.value | length > 0)
    | select(.value | all(.[]?; type == "object" and has("@id")))
    | .key as $k | .value[]."@id" | "\($k)\t\(.)"
  ' 2>/dev/null)
  [[ -z "$pairs" ]] && { printf '{}'; return 0; }
  lines=""
  while IFS=$'\t' read -r k rawid; do
    [[ -z "$k" ]] && continue
    res=$(folio_resolve_relpath "$rawid" "$subdir" "$arch_abs")
    lines+="${k}"$'\t'"${res}"$'\n'
  done <<< "$pairs"
  printf '%s' "$lines" | jq -R -s '
    [ split("\n")[] | select(length > 0) | split("\t") | {key: .[0], val: .[1]} ]
    | reduce .[] as $e ({}; .[$e.key] += [$e.val])
  '
}

# 1 spec file ($1) から inventory entry (compact JSON) を stdout に返す。
# JSON-LD block が無い / parse 不能なら return 1 (caller が skip)。 $2 = architecture 絶対 path。
folio_build_entry() {
  local f="$1" arch_abs="$2" rel subdir block doctype status version title summary stakeholders relations

  rel=$(realpath -m --relative-to="$arch_abs" "$f")   # 例 spec/relations.html
  subdir="${rel%%/*}"                                     # 例 spec

  block=$(folio_extract_head_jsonld "$f")
  [[ -z "$block" ]] && return 1                           # JSON-LD ブロック無し = scan 対象外 (§4.4.1)
  if ! printf '%s' "$block" | jq -e . >/dev/null 2>&1; then
    echo "folio inventory: WARN: JSON-LD parse error, skipping ${f}" >&2   # §4.4.3
    return 1
  fi

  # MUST fields
  doctype=$(folio_extract_meta "$f" folio-doc-type)
  status=$(folio_extract_meta "$f" folio-status)
  version=$(folio_extract_meta "$f" folio-version)

  # title: JSON-LD dc:title 優先 → <title> fallback
  title=$(printf '%s' "$block" | jq -r '."dc:title" // empty' 2>/dev/null)
  [[ -z "$title" ]] && title=$(folio_extract_title "$f")

  # summary (SHOULD): .meta 最終セグメント
  summary=$(folio_extract_summary "$f")

  # stakeholders (SHOULD): JSON-LD folio:stakeholders 配列優先 → meta split fallback
  stakeholders=$(printf '%s' "$block" | jq -c 'if (."folio:stakeholders" | type) == "array" then ."folio:stakeholders" else empty end' 2>/dev/null)
  if [[ -z "$stakeholders" ]]; then
    local meta_stake
    meta_stake=$(folio_extract_meta "$f" folio-stakeholders)
    if [[ -n "$meta_stake" ]]; then
      stakeholders=$(printf '%s' "$meta_stake" | jq -R 'split(", ")')
    else
      stakeholders="[]"
    fi
  fi

  # relations (SHOULD): JSON-LD dc:* / folio:* link プロパティ集約
  relations=$(folio_build_relations "$block" "$subdir" "$arch_abs")

  jq -n -c \
    --arg id "$rel" \
    --arg title "$title" \
    --arg summary "$summary" \
    --arg doctype "$doctype" \
    --arg status "$status" \
    --arg version "$version" \
    --argjson stakeholders "$stakeholders" \
    --argjson relations "$relations" \
    '{"@id": $id, title: $title, summary: $summary, "doc-type": $doctype, status: $status, version: $version, stakeholders: $stakeholders, relations: $relations}'
}

# folio inventory: inventory.json を生成 (REQ-VER-010 / relations.html §4)。
folio_cmd_inventory() {
  command -v jq >/dev/null 2>&1 || { echo "folio inventory: jq not found in PATH (required, fail-closed)" >&2; exit 2; }

  local plugin_json=".claude-plugin/plugin.json"
  [[ -f "$plugin_json" ]] || { echo "folio inventory: ${plugin_json} not found — run at repo root" >&2; exit 1; }

  local arch_abs
  arch_abs=$(realpath -m architecture)
  [[ -d "$arch_abs" ]] || { echo "folio inventory: architecture/ not found — run at repo root" >&2; exit 1; }

  local folio_version generated_at out_file
  folio_version=$(jq -r '.version // "unknown"' "$plugin_json")
  generated_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  out_file="$(dirname "$arch_abs")/inventory.json"

  # scan dirs: §4.4.1 order (spec → decisions → research)、 dir 内は LC_ALL=C 安定 sort。
  # constitution.html は除外 (不変 anchor、 別 schema。 find の ! -name で skip)。
  local dirs=("spec" "decisions" "research") d f entry
  local entries=()
  for d in "${dirs[@]}"; do
    local dir_abs="${arch_abs}/${d}"
    [[ -d "$dir_abs" ]] || { echo "folio inventory: scan dir missing: architecture/${d} (fatal)" >&2; exit 1; }   # §4.4.3 fs access error
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      entry=$(folio_build_entry "$f" "$arch_abs") || continue
      [[ -n "$entry" ]] && entries+=("$entry")
    done < <(find "$dir_abs" -maxdepth 1 -type f -name '*.html' ! -name 'constitution.html' | LC_ALL=C sort)
  done

  local specs_json
  if [[ ${#entries[@]} -gt 0 ]]; then
    specs_json=$(printf '%s\n' "${entries[@]}" | jq -s '.')
  else
    specs_json="[]"
  fi

  jq -n \
    --arg schema "https://folio.dev/inventory/v1.json" \
    --arg gen "$generated_at" \
    --arg ver "$folio_version" \
    --argjson specs "$specs_json" \
    '{"$schema": $schema, generatedAt: $gen, folioVersion: $ver, specs: $specs}' \
    > "$out_file"

  echo "folio inventory: wrote inventory.json (${#entries[@]} specs)" >&2
}

# ============================================================================
# prime helpers — Tier 1 digest を context へ注入 (ADR-0007、 REQ-VER-012)
# ============================================================================

# inventory.json ($1) が不在 or stale なら 0 (regen 要)、 fresh なら 1 を返す。
# ADR-0007 §2.4: spec の「追加・編集・削除」 が inventory 生成後にあれば stale。
#   - 不在                          → regen
#   - scan dir 自身が inv より新しい → 子の add/delete で dir mtime 更新 = stale
#   - 直下 .html が inv より新しい   → 内容編集 (or add) で file mtime 更新 = stale
# find -newer は strict (>) 比較。 inv は scan 後に書かれ mtime が最大のため、
# regen 直後は fresh と判定され無限 regen しない。
folio_prime_needs_regen() {
  local inv="$1" arch_abs="$2"
  [[ -f "$inv" ]] || return 0

  local d dirs=()
  for d in spec decisions research; do
    [[ -d "${arch_abs}/${d}" ]] && dirs+=("${arch_abs}/${d}")
  done
  [[ ${#dirs[@]} -eq 0 ]] && return 1   # scan dir 皆無は inventory 側で fatal、 ここでは触らない

  local newer
  newer=$(find "${dirs[@]}" -maxdepth 1 \( -type d -o -name '*.html' \) -newer "$inv" -print -quit 2>/dev/null)
  [[ -n "$newer" ]] && return 0         # stale
  return 1                              # fresh
}

# inventory.json ($1) から Tier 1 digest を stdout に出力 (relations.html §4.2 Tier 1 =
# @id / title / summary / doc-type / status)。 full relations / version / stakeholders は
# 注入しない (3-tier progressive disclosure、 ADR-0007 §2.2)。 非決定的 field (generatedAt)
# は含めない — compare:text の byte-exact golden を安定させるため。 spec 列挙順は
# inventory.json の決定的順序 (spec→decisions→research、 dir 内 LC_ALL=C) を保持する。
folio_prime_emit_digest() {
  local inv="$1" count fver body
  count=$(jq '.specs | length' "$inv")
  fver=$(jq -r '.folioVersion // "unknown"' "$inv")

  # 各 spec = 4 行 block、 block 間は空行 1。 末尾の空行は $() が除去するので
  # 最終 block 後に余分な trailing blank は残らない (byte-exact 安定)。
  body=$(jq -r '
    .specs[] |
    "## \(."@id")",
    "- title: \(.title)",
    "- doc-type: \(."doc-type") · status: \(.status)",
    "- summary: \(if (.summary // "") == "" then "(none)" else .summary end)",
    ""
  ' "$inv")

  printf '# folio inventory digest — Tier 1 (progressive disclosure)\n'
  printf '# %s specs · folio %s\n' "$count" "$fver"
  printf '# Tier 1 = @id + title + doc-type/status + summary. Read Tier 2 (head + lead para) / Tier 3 (full body) on demand.\n'
  printf '\n'
  printf '%s\n' "$body"
}

# folio prime: Tier 1 inventory digest を stdout 出力 (ADR-0007 §2.1〜2.4)。
# inventory.json が不在/stale なら folio inventory で auto-regen してから出力 (§2.4)。
# SessionStart hook からの注入経路であると同時に手動 entry point でもある (§2.3、 PreCompact は ADR-0007 amend で除去)。
folio_cmd_prime() {
  command -v jq >/dev/null 2>&1 || { echo "folio prime: jq not found in PATH (required, fail-closed)" >&2; exit 2; }

  local plugin_json=".claude-plugin/plugin.json"
  [[ -f "$plugin_json" ]] || { echo "folio prime: ${plugin_json} not found — run at repo root" >&2; exit 1; }

  local arch_abs
  arch_abs=$(realpath -m architecture)
  [[ -d "$arch_abs" ]] || { echo "folio prime: architecture/ not found — run at repo root" >&2; exit 1; }

  local inv="$(dirname "$arch_abs")/inventory.json"

  # §2.4 staleness = auto-regen (folio inventory は stderr に "wrote ..." を出す = stdout 非汚染)
  if folio_prime_needs_regen "$inv" "$arch_abs"; then
    folio_cmd_inventory
  fi
  [[ -f "$inv" ]] || { echo "folio prime: inventory.json unavailable after regen attempt" >&2; exit 1; }

  folio_prime_emit_digest "$inv"
}

# ============================================================================
# validate helpers — spec 集合の internal link-integrity + jsonld structural 検査
# (REQ-VER-013、 ADR-0020)。 jsonld 構造 check は plugin-lib.sh を共用 (§2.4 DRY)、
# link-integrity は本 file の resolve/build_relations を検査 root 注入で再利用する。
# ============================================================================

# folio validate: spec 集合 (root/{spec,decisions,research} の <head> JSON-LD .html) を
# 横断し 2 gate を検査する (REQ-VER-013、 ADR-0020 §2.1):
#   (a) internal link-integrity — JSON-LD relation @id を resolve → target file 存在 +
#       #anchor は target 内 id 存在 (REQ-CI-010 (b)+(c))
#   (b) jsonld structural — plugin-lib.sh の folio_jsonld_structural_check を共用
#       (parse + @context/@id/@type + @context==object、 REQ-CI-016、 ADR-0004 Option B Light)
# default root = architecture、 --root <dir> で検査 root を override する (test isolation、 §2.3 MUST)。
# external URL check と prose gate は試作 scope 外 (§2.2、 Phase X4+)。
# exit 0=clean / 1=violation 検出 / 2=tool error (jq 不在・root 不在等、 fail-closed)。
folio_cmd_validate() {
  # 構造 check 共有関数を plugin-lib.sh から読む (ADR-0020 §2.4 DRY)。 validate のみが
  # 依存するため lazy source (version/help/inventory/prime は plugin-lib 非依存のまま維持)。
  source "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../scripts/plugin-lib.sh" \
    || { echo "folio validate: cannot load plugin-lib.sh (fail-closed)" >&2; exit 2; }

  command -v jq >/dev/null 2>&1 || { echo "folio validate: jq not found in PATH (required, fail-closed)" >&2; exit 2; }

  # --- arg parse: --root <dir> (default architecture) ---
  local root="architecture"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --root)
        [[ $# -ge 2 ]] || { echo "folio validate: --root requires a directory argument" >&2; exit 2; }
        root="$2"; shift 2 ;;
      --root=*) root="${1#--root=}"; shift ;;
      *) echo "folio validate: unknown argument '$1' (usage: folio validate [--root <dir>])" >&2; exit 2 ;;
    esac
  done

  local root_abs
  root_abs=$(realpath -m "$root")
  [[ -d "$root_abs" ]] || { echo "folio validate: root directory not found: ${root} (fail-closed)" >&2; exit 2; }

  # --- 横断検査: spec/decisions/research のうち存在する dir のみ (検査 root の最小構成許容) ---
  # constitution.html は scan 対象外 (inventory と同基準、 find の ! -name で skip、 X4-C / ADR-0023) ---
  local dirs=("spec" "decisions" "research") d f
  local files_checked=0 relations_checked=0 link_fail=0 struct_fail=0
  local violations=()

  for d in "${dirs[@]}"; do
    local dir_abs="${root_abs}/${d}"
    [[ -d "$dir_abs" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      local block rel subdir reason
      block=$(folio_extract_head_jsonld "$f")
      [[ -z "$block" ]] && continue          # JSON-LD 無し = scan 対象外 (relations.html §4.4.1 と同基準)
      files_checked=$((files_checked + 1))
      rel=$(realpath -m --relative-to="$root_abs" "$f")   # 例 spec/relations.html (決定的・root 相対)
      subdir="${rel%%/*}"

      # gate (b) jsonld structural (共有関数、 short-circuit で最初の 1 件)
      if ! reason=$(folio_jsonld_structural_check "$block"); then
        violations+=("${rel}"$'\t'"[jsonld-structural] ${reason}")
        struct_fail=1
      fi

      # gate (a) internal link-integrity — block が parse 可能な時のみ relation 抽出
      printf '%s' "$block" | jq -e . >/dev/null 2>&1 || continue
      local relmap key resolved pathpart anchor target_abs
      relmap=$(folio_build_relations "$block" "$subdir" "$root_abs")
      while IFS=$'\t' read -r key resolved; do
        [[ -z "$key" ]] && continue
        # external URL (resolved が ':' を含む = scheme) は試作 scope 外で skip (ADR-0020 §2.2、 X4+)。
        # 正規 relpath は ':' を含まない (realpath は scheme の '//' を '/' に潰すが ':' は残る)。
        case "$resolved" in *:*) continue ;; esac
        relations_checked=$((relations_checked + 1))
        if [[ "$resolved" == *"#"* ]]; then
          pathpart="${resolved%%#*}"; anchor="${resolved#*#}"
        else
          pathpart="$resolved"; anchor=""
        fi
        target_abs="${root_abs}/${pathpart}"
        if [[ ! -f "$target_abs" ]]; then
          violations+=("${rel}"$'\t'"[link-missing-file] ${key} -> ${pathpart} (target file not found)")
          link_fail=1
        elif [[ -n "$anchor" ]]; then
          # anchor = target file 内の HTML 要素 id="..."/'...' 存在を確認 (grep -F = 固定文字列)。
          # 試作 heuristic: data-*-id 等への substring 誤一致は理論上あり得るが、 折り目正しい
          # folio spec の id naming (sN-...) では非衝突。 精緻な id parse は完成形 (ADR-0004 ajv/pyld)。
          if ! grep -qF "id=\"${anchor}\"" "$target_abs" && ! grep -qF "id='${anchor}'" "$target_abs"; then
            violations+=("${rel}"$'\t'"[link-broken-anchor] ${key} -> ${pathpart}#${anchor} (anchor id not found in target)")
            link_fail=1
          fi
        fi
      done < <(printf '%s' "$relmap" | jq -r 'to_entries[] | .key as $k | .value[] | "\($k)\t\(.)"' 2>/dev/null)
    done < <(find "$dir_abs" -maxdepth 1 -type f -name '*.html' ! -name 'constitution.html' | LC_ALL=C sort)
  done

  # --- report (stdout、 決定的: counts + per-gate status + sort 済 violation 列) ---
  printf 'folio validate — internal link-integrity + jsonld structural (ADR-0020)\n'
  printf 'root: %s\n' "$root"
  printf 'files checked: %d · relations checked: %d\n' "$files_checked" "$relations_checked"

  # per-gate status は fail flag から一意に導出 (clean なら両 [OK])。 clean/violation 分岐で
  # 重複させず、 「clean ⟹ 全 gate OK」 の不変条件を出力構造に持たせる (review R2 反映)。
  if [[ "$link_fail" -eq 1 ]]; then printf '  [FAIL] internal link-integrity\n'; else printf '  [OK] internal link-integrity\n'; fi
  if [[ "$struct_fail" -eq 1 ]]; then printf '  [FAIL] jsonld structural\n'; else printf '  [OK] jsonld structural\n'; fi

  # clean / violation は最終ブロック + exit code のみ分岐 (gate status は上で共通出力済)
  if [[ ${#violations[@]} -eq 0 ]]; then
    printf '\nclean: 0 violations\n'
    return 0
  fi

  printf '\nviolations (%d):\n' "${#violations[@]}"
  printf '%s\n' "${violations[@]}" | LC_ALL=C sort | while IFS=$'\t' read -r vfile vdetail; do
    printf '  %s %s\n' "$vfile" "$vdetail"
  done
  return 1
}

# ============================================================================
# init helpers — consumer canonical layout を scaffold (REQ-VER-014、 ADR-0024)
#   生成物 = ADR-0024 §2.1 標準 seed: architecture/{spec,decisions,research} の cluster
#   README (P-6 entry point) + spec/{constitution,overview}.html starter template +
#   verification/.gitkeep (P-13 HOW-test dir) + folio.config.yaml (§2.5 defaults)。
#   idempotent (§2.3): 既存 file は preserve (上書き禁止)、 欠損のみ生成。
#   seed .html は通常 conforming JSON-LD (@context object + @id + @type、 §2.2)、 relation @id は
#   全 resolve するため生成 skeleton は folio validate が clean (§2.4 品質ゲート)。
#   exit 0=success / 2=tool error (fail-closed)。 assets/ や CLAUDE.md/README.md は生成しない (§2.1)。
# ============================================================================

# 1 seed file を idempotent に生成。 $1 = 生成先絶対 path、 $2 = 報告用 relative base (target dir)。
# 内容は stdin (heredoc) から読む。 既存なら preserve して "exists" 報告、 欠損なら mkdir + 生成して
# "create" 報告 (target 相対 path)。 write 失敗時のみ return 1 (caller が exit 2、 fail-closed)。
folio_init_write() {
  local dest="$1" base="$2" rel
  rel=$(realpath -m --relative-to="$base" "$dest")
  if [[ -e "$dest" ]]; then
    printf 'exists  %s\n' "$rel"
    return 0
  fi
  mkdir -p "$(dirname "$dest")" || return 1
  cat > "$dest" || return 1            # stdin → file (heredoc bytes を厳密保持、 trailing newline 込み)
  printf 'create  %s\n' "$rel"
}

# folio init [<dir>]: consumer canonical layout を <dir> (省略時 cwd) に scaffold (REQ-VER-014)。
# 既存 file を preserve しつつ欠損 seed のみ生成し、 per-file の create/exists を stdout 報告する。
folio_cmd_init() {
  command -v realpath >/dev/null 2>&1 || { echo "folio init: realpath not found in PATH (required, fail-closed)" >&2; exit 2; }

  local target arch
  target=$(realpath -m "${1:-.}")
  arch="${target}/architecture"

  mkdir -p "$target" || { echo "folio init: cannot create target directory: ${target} (fail-closed)" >&2; exit 2; }
  echo "folio init: scaffolding consumer canonical layout at ${target}"

  local rc=0

  # --- folio.config.yaml (§2.5 defaults、 P-2 YAML 例外) ---
  folio_init_write "${target}/folio.config.yaml" "$target" <<'YAML' || rc=1
folio_version: "^0.5"
spec_path: "architecture/spec/"
caller_marker_env: "FOLIO_ARCHITECT_CONTEXT"
