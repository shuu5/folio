#!/usr/bin/env bash
# folio CLI skeleton (Phase X3 試作)
# 完成形は init / validate / inventory / prime / fix subcommands (ADR-0003 §2.1)
# 試作段階は version / help のみ実装

set -uo pipefail

VERSION="0.4.2-draft"

case "${1:-version}" in
  version|--version|-V)
    echo "folio v${VERSION} (Phase X3 試作)"
    ;;
  help|--help|-h)
    cat <<EOF
folio v${VERSION} — Layer 0 META FRAMEWORK CLI (Phase X3 試作)

Subcommands:
  version, --version       version 表示 (現在のみ実装)
  help, --help             本ヘルプ

Phase X3 試作で実装予定 (ADR-0003 §2.1):
  init                     consumer project の初期化
  validate                 spec の構造検証
  inventory                inventory.json 生成
  prime                    agent context inject
  fix                      自動修正 (双方向 link 等)

完成形 spec: scratch/specs/folio-self-spec.html §7.2 + ADR-0003
EOF
    ;;
  *)
    echo "folio: unknown subcommand '${1}' (Phase X3 試作では未実装)" >&2
    echo "Try 'folio help' for available subcommands." >&2
    exit 1
    ;;
esac
