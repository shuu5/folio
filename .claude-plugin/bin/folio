  # test dir は scaffold しない (ADR-0026: consumer の (b) 実装適合性 test は stack 慣習に置く、 P-13(b))

  if [[ "$rc" -ne 0 ]]; then
    echo "folio init: one or more files could not be written (fail-closed)" >&2
    exit 2
  fi

  # --- top-level index.html を生成 (ADR-0035 §2.7: init 末尾で folio build を 1 回走らせ walkable nav を
  #     materialize し即 validate clean = regen-drift を満たす)。 lazy 維持 = 実在 cluster README のみ列挙、
  #     0-part でも valid な index。 subshell で build を呼び EXIT trap (temp 掃除) を init から隔離する。
  #     再 init: 既存 generated index の curated region は build が往復保全する (editorial 保持)。 ただし marker
  #     無し hand-authored index の curated 外本文は generated-view に置換され失われるため build が事前 warn する
  #     (per-file preserve 契約は seed file 限定、 index は build 再生成が SoT)。 失敗は fail-closed。 ---
  if ! ( folio_cmd_build --root "$arch" ); then
    echo "folio init: index build failed (fail-closed)" >&2
    exit 2
  fi

  echo "folio init: done (existing files preserved, missing files created)"
}

# ============================================================================
# build helpers — graph (各 spec の head metadata + @id path-prefix cluster 分類) から
#   walkable nav view を derive (ADR-0035)。 top-level <root>/index.html を生成し、 三重
#   marker (HTML comment + meta folio-generated + 人間 banner) で hand-authored と区別する。
#   決定的 (LC_ALL=C sort + timestamp 非含有) ゆえ golden 安定・idempotent。 生成物は
#   spec/decisions/research subdir の外 (top-level) ゆえ inventory/validate の per-subdir
#   scan に出ず、 nav 専用 gate (regen-drift / dead-link / reachability) のみが対象とする。
#   SoT は graph 1 つでなく {head metadata (folio_build_entry) + @id path-prefix} の JOIN。
# ============================================================================

# HTML text content 用に & < > を escape (生成 index の title/doc-type/status 埋込、 #035)。
folio_build_htesc() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g'
}

# HTML attribute 値用に & < > " を escape (生成 index の href 埋込、 ADR-0035、 ceiling minor)。
# text 用 htesc に加え double-quote も escape し、 " を含む file 名 (= @id) が href 属性を break するのを防ぐ。
folio_build_attresc() {
  printf '%s' "$1" | sed -e 's/&/\&amp;/g' -e 's/</\&lt;/g' -e 's/>/\&gt;/g' -e 's/"/\&quot;/g'
}

# 生成 doc ($1) の curated region <!-- <name> --> ... <!-- /<name> --> ($2 = marker 名、 例
# folio:nav-curated / folio:landing-hero) の内側 (両 marker 自身は除く) を verbatim に stdout 出力する
# (ADR-0035 §2.4 curated 隔離、 ADR-0039 §2.2 が landing-hero に同 idiom を再利用)。 file 不在・
# marker 無し・region 空なら空文字。 build はこれを読み戻して再 emit し human-authored editorial を保つ
# (curated 往復保全)。 cluster section は graph から再生成、 curated は人間 SoT として round-trip する。
#
# 境界は「最初の open 行」と「最後の close 行」で取る (first-open / last-close)。 単純な state-machine
# (open で capture 開始 / close で停止) だと、 curated editorial 本文が marker を解説する <pre> 等で raw
# close marker を含むとそこで早期終端し以降を silent に切り捨てる (= #110/#116/#119 と
# 同型の raw-mention 誤動作、 ceiling 実機再現)。 first-open/last-close なら region 内の raw marker 言及を
# 内側として保全する (structural な open は必ず最初・close は必ず最後ゆえ idempotent)。 escaped marker
# (&lt;) は HTML comment にならず boundary regex に一致しないため元から無害。 marker 名は [a-z:-] のみ
# (regex メタ文字を含まない) を前提とする。
folio_build_extract_region() {
  local f="$1" name="$2" open_ln close_ln
  [[ -f "$f" ]] || return 0
  open_ln=$(grep -nE "<!--[[:space:]]*${name}[[:space:]]*-->" "$f" | head -1 | cut -d: -f1)
  close_ln=$(grep -nE "<!--[[:space:]]*/${name}[[:space:]]*-->" "$f" | tail -1 | cut -d: -f1)
  # close が open の直後 (隣接 = 空 region) なら内側ゼロ行ゆえ空を返す。 close_ln > open_ln+1 (= 間に
  # 最低 1 行) の時だけ sed する (sed の逆範囲 "N+1,N p" は GNU sed で line N+1 を出してしまう footgun 回避)。
  [[ -n "$open_ln" && -n "$close_ln" && "$close_ln" -gt "$((open_ln + 1))" ]] || return 0
  sed -n "$((open_ln + 1)),$((close_ln - 1))p" "$f"
}

# <root_abs> ($1) の specs から top-level index.html 内容を stdout に emit (純関数・決定的)。
# folio_build_entry を再利用し cluster (= @id path-prefix) ごとに doc を列挙する。 $(...) 経由でなく
# 直接 redirect/process-sub で呼ぶこと (command substitution の trailing-newline strip を回避)。
folio_build_emit_index() {
  local root_abs="$1"
  local dirs=("spec" "decisions" "research") d f entry jid jtitle jdoctype jstatus
  local rows=()
  for d in "${dirs[@]}"; do
    local dir_abs="${root_abs}/${d}"
    [[ -d "$dir_abs" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      entry=$(folio_build_entry "$f" "$root_abs") || continue
      [[ -z "$entry" ]] && continue
      jid=$(printf '%s' "$entry" | jq -r '."@id"')
      jtitle=$(printf '%s' "$entry" | jq -r '.title | gsub("[\t\n]+"; " ")')   # tab/newline を space に正規化 (IFS-tab row split 破壊回避、 ceiling minor)
      jdoctype=$(printf '%s' "$entry" | jq -r '."doc-type"')
      jstatus=$(printf '%s' "$entry" | jq -r '.status')
      rows+=("${d}"$'\t'"${jid}"$'\t'"${jtitle}"$'\t'"${jdoctype}"$'\t'"${jstatus}")
    done < <(find "$dir_abs" -maxdepth 1 -type f -name '*.html' | LC_ALL=C sort)
  done

  # curated region 往復保全 (ADR-0035 §2.4 + ADR-0039 §2.2): 既存 index の human-authored
  # editorial (nav-curated) と hero 文言 (landing-hero) を読み戻す。
  # build write path は temp→mv ゆえ emit 実行中も ${root_abs}/index.html は intact (truncate されない)。
  local curated hero
  curated=$(folio_build_extract_region "${root_abs}/index.html" "folio:nav-curated")
  hero=$(folio_build_extract_region "${root_abs}/index.html" "folio:landing-hero")

  cat <<'HEAD'
<!DOCTYPE html>
<html lang="ja">
<head>
<!-- folio:generated source=folio-build do-not-edit -->
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="folio-doc-type" content="nav-index">
<meta name="folio-generated" content="folio-build">
<meta name="folio-status" content="active">
<title>architecture — index</title>
<link rel="stylesheet" href="../common.css">
<script type="application/ld+json">
{
  "@context": { "dc": "http://purl.org/dc/terms/", "schema": "https://schema.org/", "folio": "https://folio.dev/spec/v1/" },
  "@id": "./index.html",
  "@type": "schema:CollectionPage",
  "dc:title": "architecture index"
}
</script>
</head>
<body>

<header class="doc-header">
  <h1>architecture — index</h1>
</header>

HEAD

  # --- landing hero 層 (ADR-0039 §2.2: hero 一文 → 単一 CTA → 読者別 card)。 型 (この section
  # wrapper + 既定 placeholder の構造) は build が所有し、 文言は curated region folio:landing-hero
  # に人間が author する (ADR-0033 co-author 境界と同じ線)。 region が空 (初回 build / 旧 index 移行)
  # なら決定的な placeholder を書き込む — 以後は roundtrip が人間の編集を verbatim 保全する。
  # placeholder の link は実在する cluster README のみ emit (nav-dead-link を out-of-box clean に保つ)。
  # 単一 CTA (§2.2 (2)) は placeholder では意図的に省略する: build は consumer の repo README URL を
  # 知り得ず、 相対 ../README.md は Pages で raw .md 配信・存在も非保証のため、 安全な決定的 default 先が
  # 構築不能。 偽の行き先を置くのは §2.2 の「正直でない入口を作らない」方針に反する。 CTA は人間が
  # curated region に author して 4 層を完成させる (folio-self の実例 = architecture/index.html)。 ---
  printf '<section class="landing-hero">\n<!-- folio:landing-hero -->\n'
  if [[ -n "$hero" ]]; then
    printf '%s\n' "$hero"
  else
    printf '<p class="landing-tagline">この <code>architecture/</code> は本 project の design-intent 空間です (spec = WHAT / decisions = WHY / research = exploration)。 この hero 文言は <code>folio:landing-hero</code> region を編集して project の価値提案に書き換えられます。</p>\n'
    printf '<nav class="reader-cards" aria-label="読者別の入口">\n'
    [[ -f "${root_abs}/spec/README.html" ]] && \
      printf '  <a class="reader-card" href="spec/README.html"><span class="reader-card__act">仕様・要件を調べる →</span><span class="reader-card__desc">spec — design intent (WHAT)</span></a>\n'
    [[ -f "${root_abs}/decisions/README.html" ]] && \
      printf '  <a class="reader-card" href="decisions/README.html"><span class="reader-card__act">設計の経緯を追う →</span><span class="reader-card__desc">decisions — Architecture Decision Records (WHY)</span></a>\n'
    [[ -f "${root_abs}/research/README.html" ]] && \
      printf '  <a class="reader-card" href="research/README.html"><span class="reader-card__act">探索・調査を見る →</span><span class="reader-card__desc">research — exploration</span></a>\n'
    printf '</nav>\n'
  fi
  printf '<!-- /folio:landing-hero -->\n</section>\n\n'

  # curated editorial (verbatim round-trip)。 初回移行 = marker 無し / 空 region なら空文字 = 旧挙動を
  # 維持し golden 安定。 内側 line を再 emit し最後に閉じ marker を出すことで byte-exact round-trip。
  printf '<!-- folio:nav-curated -->\n'
  [[ -n "$curated" ]] && printf '%s\n' "$curated"
  printf '<!-- /folio:nav-curated -->\n'

  # cluster section を status グルーピング + <details> 折りで emit (UX: decisions の長大 ADR 列を
  # 既定折り畳み + status 別に整理)。 status 表示順は固定 precedence → 残りは alpha 順 (決定的・golden 安定)。
  # rows は dir 順 (spec→decisions→research) かつ各 cluster 内 @id sort 済 (find|LC_ALL=C sort)。
  local cl row id ti dt st s
  local -A clname=([spec]="spec — design intent (WHAT)" [decisions]="decisions — ADR (WHY)" [research]="research — exploration")
  local -a clusters=(spec decisions research)
  local -a status_pref=(active accepted draft proposed superseded deprecated)
  for cl in "${clusters[@]}"; do
    local -a crows=()
    for row in ${rows[@]+"${rows[@]}"}; do
      [[ "${row%%$'\t'*}" == "$cl" ]] && crows+=("$row")
    done
    [[ ${#crows[@]} -eq 0 ]] && continue
    printf '<section id="cluster-%s" class="nav-cluster">\n<h2>%s</h2>\n' "$cl" "$(folio_build_htesc "${clname[$cl]}")"

    # この cluster に現れる status を precedence 順に列挙 → precedence 外は alpha 順で後置 (決定的)。
    local -a present=()
    for s in "${status_pref[@]}"; do
      for row in "${crows[@]}"; do
        IFS=$'\t' read -r _ _ _ _ st <<< "$row"
        [[ "$st" == "$s" ]] && { present+=("$s"); break; }
      done
    done
    local extra
    extra=$(for row in "${crows[@]}"; do IFS=$'\t' read -r _ _ _ _ st <<< "$row"; printf '%s\n' "$st"; done \
      | LC_ALL=C sort -u | while IFS= read -r s; do
          case " ${status_pref[*]} " in *" $s "*) ;; *) [[ -n "$s" ]] && printf '%s\n' "$s" ;; esac
        done)
    while IFS= read -r s; do [[ -n "$s" ]] && present+=("$s"); done <<< "$extra"

    # 各 status group を emit (decisions は長大ゆえ既定折り畳み、 他 cluster は open)。
    for s in "${present[@]}"; do
      local -a grp=()
      for row in "${crows[@]}"; do
        IFS=$'\t' read -r _ _ _ _ st <<< "$row"
        [[ "$st" == "$s" ]] && grp+=("$row")
      done
      [[ ${#grp[@]} -eq 0 ]] && continue
      # group が大きい (>8 entry) ときだけ既定折り畳み。 小 group は open のまま (cluster 種別でなく
      # 量で畳むので consumer corpus の規模にも適応する)。
      local openattr=" open"
      [[ ${#grp[@]} -gt 8 ]] && openattr=""
      printf '<details%s>\n<summary>%s <span class="nav-count">(%d)</span></summary>\n<ul>\n' \
        "$openattr" "$(folio_build_htesc "$s")" "${#grp[@]}"
      for row in "${grp[@]}"; do
        IFS=$'\t' read -r cl id ti dt st <<< "$row"
        printf '  <li><a href="%s">%s</a> <span class="nav-meta">%s</span></li>\n' \
          "$(folio_build_attresc "$id")" "$(folio_build_htesc "$ti")" "$(folio_build_htesc "$dt")"
      done
      printf '</ul>\n</details>\n'
    done
    printf '</section>\n\n'
  done

  # 保守者向け運用注記は末尾に置く (ADR-0039 §2.2 / P-14: 入口の最初の本文を維持者向け注記にしない —
  # 監査 wf_8b14e53a の症状 (a) の再発防止。 内容は従来と同一、 位置のみ demote)。
  cat <<'FOOT'
<aside class="informative landing-foot">
  <p class="generated-note">この index は <code>folio build</code> が graph (各 spec の head metadata + @id path-prefix cluster 分類) から自動生成します。 <strong>手編集禁止</strong> — 内容を変えるには各 cluster の spec/ADR を編集して再 build してください。 編集可能な editorial 文は hero (<code>folio:landing-hero</code>) と curated region (<code>folio:nav-curated</code>) に置きます。</p>
</aside>

</body>
</html>
FOOT
}

# canonical 名 ($1) を glossary anchor 用 slug に変換 (lowercase / 非英数の連なりを単一 hyphen / 端の hyphen 除去)。
# 例: "SSoT"→"ssot" / "canonical name"→"canonical-name" / "data-audience"→"data-audience"。 決定的。
# 空 slug (canonical が全非ASCII/全記号) は決定的 hash fallback "x<cksum>" を当てる (REQ-GLOSS-003、 ADR-0036 §2.5 S4c)。
# 連番 (term-1/term-2) は vocab 行追加で全 empty-slug anchor が shift する golden footgun ゆえ不採用。 prefix x で数字始まり id を回避。
folio_glossary_slug() {
  # LC_ALL=C で byte-based に固定し locale 非依存・決定的に (multibyte canonical でも非決定にならない、 ceiling minor)。
  # 現 vocab は ASCII canonical のみゆえ slug 非空 = fallback path 未到達 = 出力不変。
  local s
  s=$(printf '%s' "$1" | LC_ALL=C tr '[:upper:]' '[:lower:]' | LC_ALL=C sed -e 's/[^a-z0-9]\+/-/g' -e 's/^-//' -e 's/-$//')
  [[ -z "$s" ]] && s="x$(printf '%s' "$1" | LC_ALL=C cksum | cut -d' ' -f1)"   # 全非ASCII/全記号 → 決定的 hash (位置非依存)
  printf '%s' "$s"
}

# <root_abs> ($1) の vocabulary.yaml (folio-closed 語) から glossary.html 内容を stdout に emit (純関数・決定的、 ADR-0036)。
# vocab 解決不能 or term 無しなら何も出さず return 1 (= consumer で vocab 無し時は build が glossary を生成しない、 additive/keystone)。
# 定義は raw を htesc で本文 escape (data-tooltip の attribute-escape とは別 = body 表示用)。 canonical を LC_ALL=C sort で決定化。
folio_glossary_emit() {
  local root_abs="$1" vf
  vf=$(folio_glossary_vocab_path "$root_abs") || return 1
  command -v yq >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1
  # canonical\traw-definition を folio-closed 語のみ抽出 (tab/改行は space に正規化 = 行 delimiter desync 防止)、 canonical sort。
  local rows; rows=$(yq -o=json -I=0 '[.terms[] | select(.definition) | select((.domain // "folio-closed") == "folio-closed") | [.canonical, .definition]]' "$vf" 2>/dev/null \
    | jq -r '.[] | (.[0]|gsub("[\t\n]+";" ")) + "\t" + (.[1]|gsub("[\t\n]+";" "))' 2>/dev/null | LC_ALL=C sort)
  [[ -z "$rows" ]] && return 1

  # slug uniqueness 検査 (REQ-GLOSS-003、 ADR-0036 §2.5 S4c): 異なる canonical が同一 slug を生むと
  # glossary.html の <dt id="term-<slug>"> が重複し in-page anchor が壊れる。 nav-regen-drift は committed も
  # 同じ壊れ id で byte 一致ゆえ捕捉できない死角 → emit を single SoT に fail-closed で検出 (return 3、
  # vocab-absent の return 1 = keystone SKIP と弁別)。 build は no-write + error、 validate は [glossary-slug] block。
  local dup
  dup=$(while IFS=$'\t' read -r canon def; do
          [[ -z "$canon" ]] && continue
          folio_glossary_slug "$canon"; printf '\n'
        done <<< "$rows" | LC_ALL=C sort | LC_ALL=C uniq -d)
  if [[ -n "$dup" ]]; then
    printf 'folio: glossary slug 衝突 — 異なる canonical が同一 slug を生成: %s (vocabulary.yaml の canonical を一意な slug に、 REQ-GLOSS-003)\n' "$(printf '%s' "$dup" | tr '\n' ' ')" >&2
    return 3
  fi

  cat <<'HEAD'
<!DOCTYPE html>
<html lang="ja">
<head>
<!-- folio:generated source=folio-build do-not-edit -->
<meta charset="UTF-8">
<meta name="folio-doc-type" content="glossary">
<meta name="folio-generated" content="folio-build">
<meta name="folio-status" content="active">
<title>folio-vocabulary — glossary</title>
<link rel="stylesheet" href="../common.css">
<script type="application/ld+json">
{
  "@context": { "dc": "http://purl.org/dc/terms/", "schema": "https://schema.org/", "folio": "https://folio.dev/spec/v1/" },
  "@id": "./glossary.html",
  "@type": "schema:DefinedTermSet",
  "dc:title": "folio-vocabulary glossary"
}
</script>
</head>
<body>

<header class="doc-header">
  <h1>folio-vocabulary — glossary</h1>
  <div class="meta">folio-framework 語の canonical 定義 (folio build が vocabulary.yaml から生成、 ADR-0036)</div>
</header>

<aside class="informative">
  <p class="generated-note">この glossary は <code>folio build</code> が <code>vocabulary.yaml</code> (folio 所有の canonical SSoT) から自動生成します。 <strong>手編集禁止</strong> — 定義を変えるには <code>vocabulary.yaml</code> を編集して再 build してください。 spec 本文の用語 hover tooltip も同じ SSoT から供給されます (single-SoT)。</p>
</aside>

<dl class="glossary">
HEAD

  local canon def slug
  while IFS=$'\t' read -r canon def; do
    [[ -z "$canon" ]] && continue
    slug=$(folio_glossary_slug "$canon")
    printf '  <dt id="term-%s"><span class="term-name">%s</span></dt>\n  <dd>%s</dd>\n' \
      "$(folio_build_attresc "$slug")" "$(folio_build_htesc "$canon")" "$(folio_build_htesc "$def")"
  done <<< "$rows"

  printf '</dl>\n\n<p class="nav-back"><a href="./index.html">&larr; architecture index</a></p>\n</body>\n</html>\n'
}

# folio build [--root <dir>] [--check]: top-level index.html を graph から生成 (ADR-0035)。
#   companion で glossary.html も vocabulary.yaml から生成する (ADR-0036、 vocab 解決時のみ)。
#   既定 = 生成して in-place write。 --check = 生成せず committed (marker 付き) index と byte 比較し
#   drift を exit 1 で報告 (validate の regen-drift gate と同じ detect、 fix↔validate と同型)。
#   marker 無し (hand-authored・未生成) の index は drift 対象外 (keystone)。 exit 0=ok/1=drift/2=tool error。
folio_cmd_build() {
  command -v jq >/dev/null 2>&1 || { echo "folio build: jq not found in PATH (required, fail-closed)" >&2; exit 2; }
  command -v realpath >/dev/null 2>&1 || { echo "folio build: realpath not found (fail-closed)" >&2; exit 2; }

  local root="architecture" check=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --root) [[ $# -ge 2 ]] || { echo "folio build: --root requires a directory argument" >&2; exit 2; }; root="$2"; shift 2 ;;
      --root=*) root="${1#--root=}"; shift ;;
      --check) check=1; shift ;;
      *) echo "folio build: unknown argument '$1' (usage: folio build [--root <dir>] [--check])" >&2; exit 2 ;;
    esac
  done

  local root_abs; root_abs=$(realpath -m "$root")
  [[ -d "$root_abs" ]] || { echo "folio build: scan root not found: ${root} (fail-closed)" >&2; exit 2; }
  local out="${root_abs}/index.html"

  if [[ "$check" -eq 1 ]]; then
    local drift=0
    if [[ -f "$out" ]] && [[ "$(folio_extract_meta "$out" folio-generated)" == "folio-build" ]]; then
      if ! diff <(folio_build_emit_index "$root_abs") "$out" >/dev/null 2>&1; then
        echo "folio build --check: ${root}/index.html が graph から drift (folio build で再生成せよ)" >&2; drift=1
      fi
    fi
    local gout_c="${root_abs}/glossary.html" gtmp_c gec_c gout_marked=0
    if [[ -f "$gout_c" ]] && [[ "$(folio_extract_meta "$gout_c" folio-generated)" == "folio-build" ]]; then gout_marked=1; fi
    gtmp_c=$(mktemp); folio_glossary_emit "$root_abs" > "$gtmp_c" 2>/dev/null; gec_c=$?
    if [[ "$gec_c" -eq 3 ]]; then   # slug 衝突 = vocab の不変条件違反 (glossary.html の有無と独立、 validate と同 fail-closed contract、 REQ-GLOSS-003)
      echo "folio build --check: glossary slug 衝突 (vocabulary.yaml の canonical を一意な slug に修正、 REQ-GLOSS-003)" >&2; drift=1
    elif [[ "$gec_c" -eq 0 ]] && [[ "$gout_marked" -eq 1 ]] && ! diff "$gtmp_c" "$gout_c" >/dev/null 2>&1; then
      echo "folio build --check: ${root}/glossary.html が vocabulary.yaml から drift (folio build で再生成せよ)" >&2; drift=1
    elif [[ "$gec_c" -ne 0 ]] && [[ "$gec_c" -ne 3 ]] && [[ "$gout_marked" -eq 1 ]]; then   # orphan: 生成 glossary.html が在るが vocab 解決不能 (validate と対称)
      echo "folio build --check: ${root}/glossary.html が在るが vocabulary.yaml が解決しない (orphan: vocab を復元するか glossary.html を削除)" >&2; drift=1
    fi
    rm -f "$gtmp_c"
    [[ "$drift" -eq 1 ]] && return 1
    echo "folio build --check: index は graph・glossary は vocabulary.yaml と同期 (clean、 marker 無し index/glossary は対象外)" >&2
    return 0
  fi

  # 既存 index が hand-authored (marker 無し) の場合、 generated-view への置換で curated region 外の本文が
  # 失われる (curated region は emit が往復保全するが、 marker 無し index には curated marker が無く本文全体が
  # 置換対象)。 regen-drift gate が marker 無し index を keystone (対象外) 扱いするのと対称に、 build は置換前に
  # warn する (init の per-file preserve 契約は seed file のみ、 index は build が再生成する、 ceiling minor)。
  if [[ -f "$out" ]] && [[ "$(folio_extract_meta "$out" folio-generated)" != "folio-build" ]]; then
    echo "folio build: 既存の hand-authored index (${out}) を generated-view に置換します (curated region 外の本文は失われます。 必要なら curated region に移してください)" >&2
  fi

  # safe write: temp に emit してから mv で atomic 置換。 curated 往復保全のため emit は旧
  # ${root_abs}/index.html を読み戻すが、 `cmd > out` は redirect が先に out を truncate するため
  # 同 file へ直接書くと curated を読む前に消える footgun。 temp→mv で旧 index を intact に保つ。
  local tmp; tmp=$(mktemp "${root_abs}/.folio-build.XXXXXX") || { echo "folio build: mktemp failed (fail-closed)" >&2; exit 2; }
  # 失敗/signal 中断時に temp 残骸を掃除。 ${tmp:-} は trap が関数 scope 外 (subshell 終了等) で発火した際の
  # unbound (set -u) を避ける。 成功 path では mv 後に trap を解除し scope 外での冗長発火を防ぐ。
  trap 'rm -f "${tmp:-}"' EXIT INT TERM
  if folio_build_emit_index "$root_abs" > "$tmp"; then
    mv "$tmp" "$out"
    trap - EXIT INT TERM
    echo "folio build: wrote ${root}/index.html" >&2
  else
    echo "folio build: write failed: ${out} (fail-closed)" >&2; exit 2
  fi

  # glossary.html を vocabulary.yaml (folio-closed) から生成 (ADR-0036、 companion)。 vocab 解決不能 (consumer で
  # $CLAUDE_PLUGIN_ROOT 未設定・vocab 無し) なら生成しない (additive/keystone)。 safe write = temp→mv (index と同型)。
  local gout="${root_abs}/glossary.html" gtmp gec
  gtmp=$(mktemp "${root_abs}/.folio-gloss.XXXXXX") || { echo "folio build: mktemp failed (fail-closed)" >&2; exit 2; }
  trap 'rm -f "${gtmp:-}"' EXIT INT TERM
  folio_glossary_emit "$root_abs" > "$gtmp"; gec=$?   # 衝突(3) の slug 診断は stderr に流す (REQ-GLOSS-003)
  if [[ "$gec" -eq 0 ]] && [[ -s "$gtmp" ]]; then
    if [[ -f "$gout" ]] && [[ "$(folio_extract_meta "$gout" folio-generated)" != "folio-build" ]]; then
      echo "folio build: 既存の hand-authored glossary (${gout}) を generated-view に置換します (再 build で vocabulary.yaml から再生成)" >&2
    fi
    mv "$gtmp" "$gout"
    trap - EXIT INT TERM
    echo "folio build: wrote ${root}/glossary.html" >&2
  elif [[ "$gec" -eq 3 ]]; then
    rm -f "$gtmp"
    trap - EXIT INT TERM
    echo "folio build: glossary slug 衝突のため glossary.html を生成しません (上記 vocabulary.yaml を修正、 REQ-GLOSS-003)" >&2
    exit 2
  else
    rm -f "$gtmp"   # vocab 解決不能 (return 1) = glossary を生成しない (additive/keystone、 consumer の vocab 無し)
    trap - EXIT INT TERM
  fi
}

# ============================================================================
# nav 検証 helpers (ADR-0035 §2.5: dead-link + cluster-reachability gate)
# ============================================================================

# 生成 index ($1, marker 付き前提) の <a href> 相対リンクが target file/dir (+ #anchor) に解決するか検査。
# index は <root_abs> ($2) 直下に在り相対 href は root_abs 起点で解決。 stylesheet は <link> ゆえ自動除外、
# 外部 scheme / mailto / pure #anchor / *.css は明示 skip。 違反行 (file\tdetail) を stdout (無ければ空)。
# anchor 存在 check は既存 link-integrity gate と同 idiom (grep -qF id=)。 curated region の手 link rot を捕捉。
folio_nav_deadlinks() {
  local idx="$1" root_abs="$2" h pathpart anchor target_abs
  while IFS= read -r h; do
    [[ -z "$h" ]] && continue
    case "$h" in
      \#*) continue ;;          # pure anchor (同 file 内)
      *://*) continue ;;        # 外部 scheme (http(s)/file 等)
      mailto:*) continue ;;
      *.css) continue ;;        # stylesheet (念のため)
    esac
    if [[ "$h" == *"#"* ]]; then pathpart="${h%%#*}"; anchor="${h#*#}"; else pathpart="$h"; anchor=""; fi
    [[ -z "$pathpart" ]] && continue   # href="#x" は上で除外済、 href="" は self ゆえ skip
    target_abs=$(realpath -m "${root_abs}/${pathpart}")
    if [[ ! -e "$target_abs" ]]; then
      printf 'index.html\t[nav-dead-link] href "%s" -> %s (target not found)\n' "$h" "$pathpart"
    elif [[ -n "$anchor" ]] && [[ -f "$target_abs" ]]; then
      if ! grep -qF "id=\"${anchor}\"" "$target_abs" && ! grep -qF "id='${anchor}'" "$target_abs"; then
        printf 'index.html\t[nav-dead-link] href "%s" -> %s#%s (anchor id not found in target)\n' "$h" "$pathpart" "$anchor"
      fi
    fi
  done < <(grep -oP '<a [^>]*href="\K[^"]*' "$idx" 2>/dev/null)
}

# root ($1) が folio-self (framework 本体) か判定 (return 0=self / 1=consumer)。 spec/ に @type
# FolioConstitution の file が在れば self。 consumer の conforming constitution は @type schema:TechArticle
# ゆえ区別される (folio_build_entry の constitution 除外 L121 と同基準)。 reachability の block/warn 振り分けに使う。
folio_nav_is_self_root() {
  local root_abs="$1" f block
  [[ -d "${root_abs}/spec" ]] || return 1
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    block=$(folio_extract_head_jsonld "$f")
    [[ "$(printf '%s' "$block" | jq -r '."@type" // empty' 2>/dev/null)" == "FolioConstitution" ]] && return 0
  done < <(find "${root_abs}/spec" -maxdepth 1 -type f -name '*.html' 2>/dev/null)
  return 1
}

# README ($1) が自 cluster の外 (親 = architecture top-level / 他 cluster / home) へ向かう <a href> を
# 1 本以上持つか (return 0=有 / 1=dead-end)。 相対 href が '../' で始まる = cluster dir を出る、 で判定する。
# heuristic (ADR-0035 §4 で明示授権): target file の実在も sibling cluster への実到達も検査しない (../無関係
# file への link でも dead-end 回避になる)。 厳密化 (realpath -e 実在 + 自 cluster 戻り除外) は 1.0.0 後 (#119 系)。
folio_nav_has_crosslink() {
  local readme="$1" h pathpart
  while IFS= read -r h; do
    [[ -z "$h" ]] && continue
    case "$h" in \#*) continue ;; *://*) continue ;; mailto:*) continue ;; *.css) continue ;; esac
    pathpart="${h%%#*}"
    case "$pathpart" in ../*|..) return 0 ;; esac   # 親へ抜ける = cross-cluster/index/home へ到達可能
  done < <(grep -oP '<a [^>]*href="\K[^"]*' "$readme" 2>/dev/null)
  return 1
}

# README ($1) の body <a href> 相対 link が target file/dir (+ #anchor) に解決するか検査 (#128 link-rot)。
# href は README 自身の dir ($2 = cluster dir) 起点で解決 ($3 = 出力 label)。 folio_nav_deadlinks の README 版
# (index は root_abs 直下ゆえ base=root、 README は cluster dir 直下ゆえ base=cluster dir)。 has_crosslink
# (dead-end = ../ link の *存在*) と相補的で、 こちらは *存在する* href が rot していないか (target 実在) を見る。
# cluster 削除/再編で残る static cross-nav の dangling を捕捉する (link-integrity は JSON-LD relation のみ・
# nav-dead-link は生成 index のみで README body href を未被覆、 横断 audit verified MAJOR)。 外部 scheme /
# mailto / pure #anchor / *.css は skip。 違反行 (label\tdetail) を stdout (無ければ空)。
# 限界 (interim、 既存 nav-dead-link と同 idiom 継承): inline <code> 内 illustrative href も実 link として拾い
# (folio_prose_only mask 未適用)、 query-string (?v=) を strip せず・大文字 HREF / single-quote href も非対象。
# live corpus は全て無害。 mask 一般化 + query strip + 非 README body href 被覆は #119 系で parity 一括解消する。
folio_nav_readme_deadlinks() {
  local readme="$1" base_abs="$2" label="$3" h pathpart anchor target_abs
  while IFS= read -r h; do
    [[ -z "$h" ]] && continue
    case "$h" in
      \#*) continue ;;          # pure anchor (同 file 内)
      *://*) continue ;;        # 外部 scheme
      mailto:*) continue ;;
      *.css) continue ;;        # stylesheet
    esac
    if [[ "$h" == *"#"* ]]; then pathpart="${h%%#*}"; anchor="${h#*#}"; else pathpart="$h"; anchor=""; fi
    [[ -z "$pathpart" ]] && continue
    target_abs=$(realpath -m "${base_abs}/${pathpart}")
    if [[ ! -e "$target_abs" ]]; then
      printf '%s\t[cluster-reachability] README href "%s" -> %s (link-rot: target not found)\n' "$label" "$h" "$pathpart"
    elif [[ -n "$anchor" ]] && [[ -f "$target_abs" ]]; then
      if ! grep -qF "id=\"${anchor}\"" "$target_abs" && ! grep -qF "id='${anchor}'" "$target_abs"; then
        printf '%s\t[cluster-reachability] README href "%s" -> %s#%s (link-rot: anchor id not found in target)\n' "$label" "$h" "$pathpart" "$anchor"
      fi
    fi
  done < <(grep -oP '<a [^>]*href="\K[^"]*' "$readme" 2>/dev/null)
}

# cluster-reachability (ADR-0035 §2.5 part B + empty-cluster blind spot)。 各 cluster dir について:
#  (1) dir 存在かつ scannable doc 0 = empty cluster を flag (regen-drift は空 cluster の section silent
#      省略を検出できない盲点。 cluster 丸ごと欠落をここで捕捉)。
#  (2) doc 在りかつ README.html 在る場合、 README が自 cluster 外へ向かう link を持つか (dead-end 検出、
#      現 research/README が該当)。
#  (3) README 存在時、 その body <a href> 相対 link が rot (target 不在) していないか (#128 link-rot)。
#      (2) は cross-link の *存在* を見る heuristic、 (3) は *存在する* link の target 実在を見る相補的検査。
#      cluster 削除/再編で残る static cross-nav の dangling を捕捉 (folio_nav_readme_deadlinks)。
# part A (index→全 doc 到達) は完全生成 index では regen-drift に内包される (index = emit が全 doc 列挙)
# ため独立 gate 化しない (Slice 1 で確立した subsume 判断と同型)。 違反行 (file\tdetail) を stdout に出力、
# caller が self=block / consumer=warn を振り分ける。
folio_nav_reachability() {
  local root_abs="$1" cl dir_abs ndocs readme f
  for cl in spec decisions research; do
    dir_abs="${root_abs}/${cl}"
    [[ -d "$dir_abs" ]] || continue
    ndocs=0
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      folio_build_entry "$f" "$root_abs" >/dev/null 2>&1 && ndocs=$((ndocs + 1))
    done < <(find "$dir_abs" -maxdepth 1 -type f -name '*.html' 2>/dev/null | LC_ALL=C sort)
    if [[ "$ndocs" -eq 0 ]]; then
      printf '%s\t[cluster-reachability] cluster dir exists but has 0 nav-reachable docs (empty cluster = regen-drift blind spot、 ADR-0035 §2.5)\n' "${cl}/"
      continue
    fi
    readme="${dir_abs}/README.html"
    [[ -f "$readme" ]] || continue
    if ! folio_nav_has_crosslink "$readme"; then
      printf '%s\t[cluster-reachability] cluster README is a dead-end (自 cluster 外への <a href> 無し、 他 cluster / ../index.html / home link を追加せよ)\n' "${cl}/README.html"
    fi
    # (3) link-rot (#128): README の cross-nav/prose 相対 href が target 実在に解決するか。 base = cluster dir。
    folio_nav_readme_deadlinks "$readme" "$dir_abs" "${cl}/README.html"
  done
}

# ============================================================================
# dispatch
# ============================================================================

case "${1:-version}" in
  version|--version|-V)
    echo "folio v${VERSION} (Phase X3 試作)"
    ;;
  help|--help|-h)
    cat <<EOF
folio v${VERSION} — Layer 0 META FRAMEWORK CLI (Phase X3 試作)

Subcommands:
  version, --version       version 表示
  help, --help             本ヘルプ
  init [<dir>]             consumer canonical layout を scaffold (省略時 cwd、 ADR-0024)
                           (idempotent: 既存 file preserve、 exit 0=success/2=tool error)
  inventory [--root <dir>] inventory.json 生成 (relations.html §4、 default cwd/architecture、
                           --root で scan/output root を override = validate/fix と対称)
  prime [--root <dir>]     Tier 1 inventory digest を stdout 出力 (ADR-0007、 不在/stale 時 auto-regen、
                           --root で scan/inventory.json 場所を override = inventory と対称)
  validate [--root <dir>]  spec 集合の internal link-integrity + jsonld structural +
                           broken-reverse 検査 (ADR-0020/0025 3-gate、 exit 0=clean/1=violation/2=tool error、
                           --root で検査 root override)
  fix [--root <dir>]       forward A→B (6 dual pair、 B が scan 対象) の reverse B→A を target に
                           materialize (双方向 link、 ADR-0025、 idempotent、 exit 0=success/2=tool error)
  build [--root <dir>]     graph から top-level index.html (walkable nav) を生成 (ADR-0035、 三重 marker、
        [--check]          決定的・idempotent、 --check で drift 検査 exit 0=ok/1=drift、 既定 write 0=ok/2=error)

完成形 spec: architecture/spec/folio-self-spec.html §7.2 + ADR-0003
EOF
    ;;
  init)
    shift
    folio_cmd_init "$@"
    exit $?
    ;;
  inventory)
    shift
    folio_cmd_inventory "$@"
    ;;
  prime)
    shift
    folio_cmd_prime "$@"
    ;;
  validate)
    shift
    folio_cmd_validate "$@"
    exit $?
    ;;
  fix)
    shift
    folio_cmd_fix "$@"
    exit $?
    ;;
  build)
    shift
    folio_cmd_build "$@"
    exit $?
    ;;
  *)
    echo "folio: unknown subcommand '${1}' (Phase X3 試作では未実装)" >&2
    echo "Try 'folio help' for available subcommands." >&2
    exit 1
    ;;
esac
