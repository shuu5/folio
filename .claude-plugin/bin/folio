#!/usr/bin/env bash
# folio CLI (Phase X3 試作)
# 完成形は init / validate / inventory / prime / fix subcommands (ADR-0003 §2.1)
# 試作段階は version / help / init / inventory / prime / validate を実装
#
# inventory subcommand (REQ-VER-010):
#   relations.html §4.4.1 の scan 対象 (architecture/spec/ + architecture/decisions/ +
#   architecture/research/ の <head> JSON-LD を持つ .html) を走査し、 §4.1 schema 準拠の
#   inventory.json を生成する (走査 base = architecture/、 出力先 = repo-root を decouple)。
#   constitution.html は spec graph の対象外 (不変 framework anchor、 FolioConstitution schema =
#   spec の @context-object+@id 規約と別形) のため scan から除外する (X4-C / ADR-0023)。
#   cwd = repo root 前提 (REQ-VER-011 「at repo root」)。
#   依存: jq / grep -P / awk / realpath / date (python 等の追加 runtime 依存なし、
#   既存 plugin (bin/folio / runner.sh / *.sh) の bash idiom に統一)。

set -uo pipefail

VERSION="0.4.2-draft"

# ============================================================================
# inventory helpers — HTML spec から field 抽出 (folio 自身の整った spec 群が対象)
# ============================================================================

# <head> 内の最初の application/ld+json ブロック本文を stdout に返す (無ければ空)。
# </head> 到達で打ち切るため body 中の (エスケープされた) 言及には反応しない:
#   prose の `&lt;script type="application/ld+json"&gt;` は `<script` に一致しないので除外。
folio_extract_head_jsonld() {
  awk '
    /<\/head>/ { exit }
    capturing && /<\/script>/ { exit }
    capturing { print }
    /<script[^>]*type="application\/ld\+json"/ { capturing = 1 }
  ' "$1"
}

# <meta name="$2" content="..."> の content を stdout に返す (無ければ空文字)。
folio_extract_meta() {
  grep -oP "<meta name=\"$2\" content=\"\K[^\"]*" "$1" 2>/dev/null | head -1
}

# <title>...</title> の text を stdout に返す。
folio_extract_title() {
  grep -oP '<title>\K[^<]*' "$1" 2>/dev/null | head -1
}

# <header> .meta div の最終 &middot; セグメントを summary として返す
# (§4.1 source: spec <header> .meta)。 HTML entity を最小 decode + trim。
folio_extract_summary() {
  local meta seg
  meta=$(grep -oP '<div class="meta">\K[^<]*' "$1" 2>/dev/null | head -1)
  [[ -z "$meta" ]] && return 0
  seg="$meta"
  [[ "$meta" == *"&middot;"* ]] && seg="${meta##*&middot;}"
  # trim 前後 whitespace
  seg="${seg#"${seg%%[![:space:]]*}"}"
  seg="${seg%"${seg##*[![:space:]]}"}"
  printf '%s' "$seg" | sed -e 's/&amp;/\&/g; s/&lt;/</g; s/&gt;/>/g; s/&quot;/"/g; s/&#39;/'"'"'/g; s/&middot;/·/g'
}

# 相対 @id ($1) を、 その spec が属する subdir ($2) 起点で解決し architecture ($3) 相対へ
# 正規化して返す。 #anchor は保持。 例 (subdir=spec):
#   ./rules.html#s4-format        -> spec/rules.html#s4-format
#   ./constitution.html           -> spec/constitution.html
#   ../research/foo.html          -> research/foo.html
folio_resolve_relpath() {
  local rawid="$1" subdir="$2" arch_abs="$3" pathpart anchor resolved
  if [[ "$rawid" == *"#"* ]]; then
    pathpart="${rawid%%#*}"
    anchor="#${rawid#*#}"
  else
    pathpart="$rawid"
    anchor=""
  fi
  resolved=$(realpath -m --relative-to="$arch_abs" "${arch_abs}/${subdir}/${pathpart}")
  printf '%s%s' "$resolved" "$anchor"
}

# JSON-LD block ($1) から relation を集約した object を返す (§4.1 specs[].relations)。
# relation = 値が [{ "@id": ... }, ...] 形式の dc:* / folio:* 等のプロパティ
# (dc:title=string / folio:version=string / folio:stakeholders=[string] は形が違うので自動除外)。
# 各 @id は subdir ($2) 起点で architecture ($3) 相対へ正規化。 無ければ "{}"。
folio_build_relations() {
  local block="$1" subdir="$2" arch_abs="$3" pairs lines k rawid res
  pairs=$(printf '%s' "$block" | jq -r '
    to_entries[]
    | select(.value | type == "array")
    | select(.value | length > 0)
    | select(.value | all(.[]?; type == "object" and has("@id")))
    | .key as $k | .value[]."@id" | "\($k)\t\(.)"
  ' 2>/dev/null)
  [[ -z "$pairs" ]] && { printf '{}'; return 0; }
  lines=""
  while IFS=$'\t' read -r k rawid; do
    [[ -z "$k" ]] && continue
    res=$(folio_resolve_relpath "$rawid" "$subdir" "$arch_abs")
    lines+="${k}"$'\t'"${res}"$'\n'
  done <<< "$pairs"
  printf '%s' "$lines" | jq -R -s '
    [ split("\n")[] | select(length > 0) | split("\t") | {key: .[0], val: .[1]} ]
    | reduce .[] as $e ({}; .[$e.key] += [$e.val])
  '
}

# 1 spec file ($1) から inventory entry (compact JSON) を stdout に返す。
# JSON-LD block が無い / parse 不能なら return 1 (caller が skip)。 $2 = architecture 絶対 path。
folio_build_entry() {
  local f="$1" arch_abs="$2" rel subdir block doctype status version title summary stakeholders relations

  rel=$(realpath -m --relative-to="$arch_abs" "$f")   # 例 spec/relations.html
  subdir="${rel%%/*}"                                     # 例 spec

  block=$(folio_extract_head_jsonld "$f")
  [[ -z "$block" ]] && return 1                           # JSON-LD ブロック無し = scan 対象外 (§4.4.1)
  if ! printf '%s' "$block" | jq -e . >/dev/null 2>&1; then
    echo "folio inventory: WARN: JSON-LD parse error, skipping ${f}" >&2   # §4.4.3
    return 1
  fi

  # FolioConstitution schema = 不変 framework anchor、 spec graph scan 除外 (schema-based、 ADR-0023 / ADR-0024 §2.2)。
  # 名前ではなく @type で識別するため、 consumer の conforming constitution (@type=schema:TechArticle) は scan される。
  [[ "$(printf '%s' "$block" | jq -r '."@type" // empty' 2>/dev/null)" == "FolioConstitution" ]] && return 1

  # MUST fields
  doctype=$(folio_extract_meta "$f" folio-doc-type)
  status=$(folio_extract_meta "$f" folio-status)
  version=$(folio_extract_meta "$f" folio-version)

  # title: JSON-LD dc:title 優先 → <title> fallback
  title=$(printf '%s' "$block" | jq -r '."dc:title" // empty' 2>/dev/null)
  [[ -z "$title" ]] && title=$(folio_extract_title "$f")

  # summary (SHOULD): .meta 最終セグメント
  summary=$(folio_extract_summary "$f")

  # stakeholders (SHOULD): JSON-LD folio:stakeholders 配列優先 → meta split fallback
  stakeholders=$(printf '%s' "$block" | jq -c 'if (."folio:stakeholders" | type) == "array" then ."folio:stakeholders" else empty end' 2>/dev/null)
  if [[ -z "$stakeholders" ]]; then
    local meta_stake
    meta_stake=$(folio_extract_meta "$f" folio-stakeholders)
    if [[ -n "$meta_stake" ]]; then
      stakeholders=$(printf '%s' "$meta_stake" | jq -R 'split(", ")')
    else
      stakeholders="[]"
    fi
  fi

  # relations (SHOULD): JSON-LD dc:* / folio:* link プロパティ集約
  relations=$(folio_build_relations "$block" "$subdir" "$arch_abs")

  jq -n -c \
    --arg id "$rel" \
    --arg title "$title" \
    --arg summary "$summary" \
    --arg doctype "$doctype" \
    --arg status "$status" \
    --arg version "$version" \
    --argjson stakeholders "$stakeholders" \
    --argjson relations "$relations" \
    '{"@id": $id, title: $title, summary: $summary, "doc-type": $doctype, status: $status, version: $version, stakeholders: $stakeholders, relations: $relations}'
}

# folio inventory: inventory.json を生成 (REQ-VER-010 / relations.html §4)。
folio_cmd_inventory() {
  command -v jq >/dev/null 2>&1 || { echo "folio inventory: jq not found in PATH (required, fail-closed)" >&2; exit 2; }

  # --- arg parse: --root <dir> (default architecture、 validate/fix と対称、 #92) ---
  local root="architecture"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --root) [[ $# -ge 2 ]] || { echo "folio inventory: --root requires a directory argument" >&2; exit 2; }; root="$2"; shift 2 ;;
      --root=*) root="${1#--root=}"; shift ;;
      *) echo "folio inventory: unknown argument '$1' (usage: folio inventory [--root <dir>])" >&2; exit 2 ;;
    esac
  done

  # plugin.json は実行中の bin/folio の隣にある (cwd 依存を排除、 #92)。
  local script_dir; script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local plugin_json="${script_dir}/../plugin.json"
  [[ -f "$plugin_json" ]] || { echo "folio inventory: plugin manifest が無い (${plugin_json}、 install 破損疑い)" >&2; exit 1; }

  local arch_abs
  arch_abs=$(realpath -m "$root")
  [[ -d "$arch_abs" ]] || { echo "folio inventory: scan root not found: ${root} (--root で指定するか cwd/architecture を用意)" >&2; exit 1; }

  local folio_version generated_at out_file
  folio_version=$(jq -r '.version // "unknown"' "$plugin_json")
  generated_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  out_file="$(dirname "$arch_abs")/inventory.json"

  # scan dirs: §4.4.1 order (spec → decisions → research)、 dir 内は LC_ALL=C 安定 sort。
  # FolioConstitution schema の constitution は build_entry が @type で schema-based に skip (名前非依存、 ADR-0024 §2.2)。
  local dirs=("spec" "decisions" "research") d f entry
  local entries=()
  for d in "${dirs[@]}"; do
    local dir_abs="${arch_abs}/${d}"
    [[ -d "$dir_abs" ]] || { echo "folio inventory: scan dir missing: ${root}/${d} (fatal)" >&2; exit 1; }   # §4.4.3 fs access error
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      entry=$(folio_build_entry "$f" "$arch_abs") || continue
      [[ -n "$entry" ]] && entries+=("$entry")
    done < <(find "$dir_abs" -maxdepth 1 -type f -name '*.html' | LC_ALL=C sort)
  done

  local specs_json
  if [[ ${#entries[@]} -gt 0 ]]; then
    specs_json=$(printf '%s\n' "${entries[@]}" | jq -s '.')
  else
    specs_json="[]"
  fi

  # object-graph projection (ADR-0034 §2.7、 既存 projection を object-level に additive 拡張)。
  # node = canonical object (principle/requirement/decision) + essence、 edge = in-band xref 集計。
  # 決定的 (sort + timestamp 非含有) ゆえ golden 安定。 既存 field ($schema/generatedAt/folioVersion/specs) は不変。
  local objectgraph_json; objectgraph_json=$(folio_xref_build_objectgraph "$arch_abs")

  jq -n \
    --arg schema "https://folio.dev/inventory/v1.json" \
    --arg gen "$generated_at" \
    --arg ver "$folio_version" \
    --argjson specs "$specs_json" \
    --argjson og "$objectgraph_json" \
    '{"$schema": $schema, generatedAt: $gen, folioVersion: $ver, specs: $specs, objectGraph: $og}' \
    > "$out_file"

  local og_n; og_n=$(printf '%s' "$objectgraph_json" | jq '.nodes | length')
  echo "folio inventory: wrote inventory.json (${#entries[@]} specs, ${og_n} object-graph nodes)" >&2
}

# ============================================================================
# prime helpers — Tier 1 digest を context へ注入 (ADR-0007、 REQ-VER-012)
# ============================================================================

# inventory.json ($1) が不在 or stale なら 0 (regen 要)、 fresh なら 1 を返す。
# ADR-0007 §2.4: spec の「追加・編集・削除」 が inventory 生成後にあれば stale。
#   - 不在                          → regen
#   - scan dir 自身が inv より新しい → 子の add/delete で dir mtime 更新 = stale
#   - 直下 .html が inv より新しい   → 内容編集 (or add) で file mtime 更新 = stale
# find -newer は strict (>) 比較。 inv は scan 後に書かれ mtime が最大のため、
# regen 直後は fresh と判定され無限 regen しない。
folio_prime_needs_regen() {
  local inv="$1" arch_abs="$2"
  [[ -f "$inv" ]] || return 0

  local d dirs=()
  for d in spec decisions research; do
    [[ -d "${arch_abs}/${d}" ]] && dirs+=("${arch_abs}/${d}")
  done
  [[ ${#dirs[@]} -eq 0 ]] && return 1   # scan dir 皆無は inventory 側で fatal、 ここでは触らない

  local newer
  newer=$(find "${dirs[@]}" -maxdepth 1 \( -type d -o -name '*.html' \) -newer "$inv" -print -quit 2>/dev/null)
  [[ -n "$newer" ]] && return 0         # stale
  return 1                              # fresh
}

# inventory.json ($1) から Tier 1 digest を stdout に出力 (relations.html §4.2 Tier 1 =
# @id / title / summary / doc-type / status)。 full relations / version / stakeholders は
# 注入しない (3-tier progressive disclosure、 ADR-0007 §2.2)。 非決定的 field (generatedAt)
# は含めない — compare:text の byte-exact golden を安定させるため。 spec 列挙順は
# inventory.json の決定的順序 (spec→decisions→research、 dir 内 LC_ALL=C) を保持する。
folio_prime_emit_digest() {
  local inv="$1" count fver body
  count=$(jq '.specs | length' "$inv")
  fver=$(jq -r '.folioVersion // "unknown"' "$inv")

  # 各 spec = 4 行 block、 block 間は空行 1。 末尾の空行は $() が除去するので
  # 最終 block 後に余分な trailing blank は残らない (byte-exact 安定)。
  body=$(jq -r '
    .specs[] |
    "## \(."@id")",
    "- title: \(.title)",
    "- doc-type: \(."doc-type") · status: \(.status)",
    "- summary: \(if (.summary // "") == "" then "(none)" else .summary end)",
    ""
  ' "$inv")

  printf '# folio inventory digest — Tier 1 (progressive disclosure)\n'
  printf '# %s specs · folio %s\n' "$count" "$fver"
  printf '# Tier 1 = @id + title + doc-type/status + summary. Read Tier 2 (head + lead para) / Tier 3 (full body) on demand.\n'
  printf '\n'
  printf '%s\n' "$body"

  # object-graph index (ADR-0034 §2.7 compact object-index、 in-context AI navigation 用)。 各 node 1 行
  # (id + class + SSoT-location)。 essence は inventory.json objectGraph.nodes[].essence に格納。 順序は
  # id+ssot で決定的 (byte-exact 安定)。 objectGraph 不在の旧 inventory は 0 行 (// [] で後方互換)。
  local og_count og_body
  og_count=$(jq '(.objectGraph.nodes // []) | length' "$inv")
  og_body=$(jq -r '(.objectGraph.nodes // []) | sort_by(.id, .ssot) | .[] | "\(.id) [\(.class)] \(.ssot)"' "$inv")
  printf '\n'
  printf '# object-graph index — %s canonical objects (ADR-0034、 principle / requirement / decision、 xref SSoT)\n' "$og_count"
  printf '# <id> [<class>] <ssot-location>. tooltip essence は inventory.json objectGraph.nodes[].essence。\n'
  [[ -n "$og_body" ]] && printf '%s\n' "$og_body"
}

# folio prime: Tier 1 inventory digest を stdout 出力 (ADR-0007 §2.1〜2.4)。
# inventory.json が不在/stale なら folio inventory で auto-regen してから出力 (§2.4)。
# SessionStart hook からの注入経路であると同時に手動 entry point でもある (§2.3、 PreCompact は ADR-0007 amend で除去)。
folio_cmd_prime() {
  command -v jq >/dev/null 2>&1 || { echo "folio prime: jq not found in PATH (required, fail-closed)" >&2; exit 2; }

  # --- arg parse: --root <dir> (default architecture、 validate/fix/inventory と対称) ---
  local root="architecture"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --root) [[ $# -ge 2 ]] || { echo "folio prime: --root requires a directory argument" >&2; exit 2; }; root="$2"; shift 2 ;;
      --root=*) root="${1#--root=}"; shift ;;
      *) echo "folio prime: unknown argument '$1' (usage: folio prime [--root <dir>])" >&2; exit 2 ;;
    esac
  done

  # plugin.json は実行中の bin/folio の隣にある (cwd 依存排除、 #92 と対称)。
  local script_dir; script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local plugin_json="${script_dir}/../plugin.json"
  [[ -f "$plugin_json" ]] || { echo "folio prime: plugin manifest が無い (${plugin_json}、 install 破損疑い)" >&2; exit 1; }

  local arch_abs
  arch_abs=$(realpath -m "$root")
  [[ -d "$arch_abs" ]] || { echo "folio prime: scan root not found: ${root} (--root で指定するか cwd/architecture を用意)" >&2; exit 1; }

  local inv="$(dirname "$arch_abs")/inventory.json"

  # §2.4 staleness = auto-regen。 --root を inventory に forward する (対称、 stale-regen が --root 起源の inv を上書きしない)。
  if folio_prime_needs_regen "$inv" "$arch_abs"; then
    folio_cmd_inventory --root "$root"
  fi
  [[ -f "$inv" ]] || { echo "folio prime: inventory.json unavailable after regen attempt" >&2; exit 1; }

  folio_prime_emit_digest "$inv"
}

# ============================================================================
# bidirectional helpers — reverse relation の検出 / materialize (fix + validate gate c)
#   relations.html §5.1 の 6 dual pair (forward → reverse) を共有定義し、 fix
#   (folio_cmd_fix = REQ-REL-002 remediate) と validate broken-reverse gate
#   (folio_cmd_validate gate (c) = REQ-REL-004 detect) が同一の scan-target 判定 +
#   reverse 探索ロジックを使う (detect↔remediate 対称性、 ADR-0025 §2)。
# ============================================================================

# forward relation key ($1) に対応する reverse key を stdout に返す (§5.1 の 6 dual pair)。
# 6 pair 以外 (reverse key 自身 / dc:requires / prov:* 等) は空文字 = reverse 対象外。
folio_reverse_of() {
  case "$1" in
    "dc:replaces")      printf 'dc:isReplacedBy' ;;
    "dc:references")    printf 'dc:isReferencedBy' ;;
    "dc:hasPart")       printf 'dc:isPartOf' ;;
    "folio:depends-on") printf 'folio:depended-by' ;;
    "folio:extends")    printf 'folio:extended-by' ;;
    "folio:implements") printf 'folio:implemented-by' ;;
    *)                  printf '' ;;
  esac
}

# target ($1=絶対 path, $2=root 相対 path) が spec graph の scan 対象かを判定 (return 0/1)。
# inventory (folio_build_entry) / validate と完全同一基準: (1) scan dir (spec/decisions/research)
# 配下、 (2) head JSON-LD を持ち、 (3) parse 可能で、 (4) @type != FolioConstitution。
# fix/gate は scan 対象にのみ reverse を materialize/要求する (constitution・head 無し research・
# scan dir 外の target は除外 = forward があっても reverse 不要、 ADR-0025 §2.1 edge case)。
folio_is_scan_target() {
  local target_abs="$1" target_rel="$2" tblock
  case "${target_rel%%/*}" in spec|decisions|research) ;; *) return 1 ;; esac
  [[ -f "$target_abs" ]] || return 1
  tblock=$(folio_extract_head_jsonld "$target_abs")
  [[ -z "$tblock" ]] && return 1
  printf '%s' "$tblock" | jq -e . >/dev/null 2>&1 || return 1
  [[ "$(printf '%s' "$tblock" | jq -r '."@type" // empty' 2>/dev/null)" == "FolioConstitution" ]] && return 1
  return 0
}

# source A ($1 = root 相対 path) を target B の subdir ($2) 起点で見た相対 @id へ変換し stdout に
# 返す (B 上に置く reverse link B→A の @id)。 folio_resolve_relpath の逆 — realpath --relative-to で
# B の dir から A への相対 path を算出、 folio convention (同/子 dir = ./foo、 上位/兄弟 = ../dir/foo)
# へ正規化。 anchor は付けない (reverse は file 単位)。 $3 = root 絶対 path。
folio_reverse_relid() {
  local source_rel="$1" target_subdir="$2" root_abs="$3" relid
  relid=$(realpath -m --relative-to="${root_abs}/${target_subdir}" "${root_abs}/${source_rel}")
  case "$relid" in
    ../*) ;;
    *)    relid="./${relid}" ;;
  esac
  printf '%s' "$relid"
}

# target B ($1=絶対, $2=subdir) の reverse_key ($3) 配列が source A ($4 = root 相対 path) を指す
# @id を既に持つか判定 (return 0 = 既存 / 1 = 欠落)。 idempotency (fix) + broken-reverse gate
# (validate) で共用。 B の reverse @id を folio_resolve_relpath で root 相対へ解決し A と一致比較
# (./foo vs foo 等の表記揺れと anchor を吸収)。 $5 = root 絶対 path。
folio_target_has_reverse() {
  local target_abs="$1" target_subdir="$2" rev_key="$3" source_rel="$4" root_abs="$5"
  local tblock id resolved
  tblock=$(folio_extract_head_jsonld "$target_abs")
  [[ -z "$tblock" ]] && return 1
  while IFS= read -r id; do
    [[ -z "$id" ]] && continue
    resolved=$(folio_resolve_relpath "$id" "$target_subdir" "$root_abs")
    [[ "${resolved%%#*}" == "$source_rel" ]] && return 0
  done < <(printf '%s' "$tblock" | jq -r --arg k "$rev_key" '.[$k]? // [] | .[]? | .["@id"] // empty' 2>/dev/null)
  return 1
}

# target B ($1=絶対, $2=root 相対 path, $3=root 絶対) の <head> JSON-LD へ owed reverse を
# materialize する。 stdin = "rev_key\tsource_rel" 行 (この B に owed な reverse、 重複可)。
# 既存 reverse は重複追加しない (idempotent)。 追加した @id 数を stdout に返す (0=変更なし)。
# 最小 diff 方針 = 既存行を一切変更せず追加のみ:
#   - rev_key 不在 → @type 行直後に新 key block を挿入 (key 名 sort、 @id は source sort)
#   - rev_key 既存 → 当該配列の "[" 行直後に新 element を挿入 (既存末尾 element を変更しない)
# awk 失敗時は file を破壊せず return 1 (caller が fail-closed)。
folio_materialize_reverse() {
  local target_abs="$1" target_rel="$2" root_abs="$3"
  local target_subdir="${target_rel%%/*}"
  local owed; owed=$(LC_ALL=C sort -u)
  [[ -z "$owed" ]] && { printf '0'; return 0; }

  local tblock; tblock=$(folio_extract_head_jsonld "$target_abs")
  [[ -z "$tblock" ]] && { printf '0'; return 0; }

  local rev_keys; rev_keys=$(printf '%s\n' "$owed" | cut -f1 | LC_ALL=C sort -u)
  local added=0
  local -a create_kb=()
  local append_file; append_file=$(mktemp)

  local rk
  while IFS= read -r rk; do
    [[ -z "$rk" ]] && continue
    local present=0
    printf '%s' "$tblock" | jq -e --arg k "$rk" 'has($k)' >/dev/null 2>&1 && present=1
    local -a relids=()
    local sr relid
    while IFS= read -r sr; do
      [[ -z "$sr" ]] && continue
      folio_target_has_reverse "$target_abs" "$target_subdir" "$rk" "$sr" "$root_abs" && continue
      relid=$(folio_reverse_relid "$sr" "$target_subdir" "$root_abs")
      relids+=("$relid")
    done < <(printf '%s\n' "$owed" | awk -F'\t' -v k="$rk" '$1==k{print $2}' | LC_ALL=C sort -u)
    [[ ${#relids[@]} -eq 0 ]] && continue
    added=$((added + ${#relids[@]}))
    if [[ "$present" -eq 1 ]]; then
      local r
      for r in "${relids[@]}"; do
        printf '%s\t    { "@id": "%s" },\n' "$rk" "$r" >> "$append_file"
      done
    else
      local kb i n=${#relids[@]}
      kb="  \"${rk}\": ["$'\n'
      for ((i=0; i<n; i++)); do
        if [[ $i -lt $((n-1)) ]]; then kb+="    { \"@id\": \"${relids[$i]}\" },"$'\n'
        else kb+="    { \"@id\": \"${relids[$i]}\" }"$'\n'; fi
      done
      kb+="  ]"
      create_kb+=("$kb")
    fi
  done <<< "$rev_keys"

  if [[ "$added" -eq 0 ]]; then rm -f "$append_file"; printf '0'; return 0; fi

  local create_file; create_file=$(mktemp)
  local type_is_last=0
  if [[ ${#create_kb[@]} -gt 0 ]]; then
    [[ "$(printf '%s' "$tblock" | jq -r 'keys_unsorted | last')" == "@type" ]] && type_is_last=1
    local j m=${#create_kb[@]}
    for ((j=0; j<m; j++)); do
      printf '%s' "${create_kb[$j]}" >> "$create_file"
      if [[ $j -lt $((m-1)) ]]; then printf ',\n' >> "$create_file"
      elif [[ "$type_is_last" -eq 1 ]]; then printf '\n' >> "$create_file"
      else printf ',\n' >> "$create_file"; fi
    done
  fi

  local out; out=$(mktemp)
  if awk -v createfile="$create_file" -v appendfile="$append_file" -v typecomma="$type_is_last" '
    BEGIN {
      while ((getline l < createfile) > 0) createtext = createtext l "\n";
      while ((getline l < appendfile) > 0) {
        t = index(l, "\t"); appmap[substr(l, 1, t-1)] = appmap[substr(l, 1, t-1)] substr(l, t+1) "\n";
      }
    }
    { if (!past_head && /<\/head>/) past_head = 1;
      if (!past_head && /<script[^>]*type="application\/ld\+json"/) inld = 1; }
    (inld && !donecreate && /^[[:space:]]*"@type":/) {
      line = $0;
      if (typecomma == "1" && createtext != "" && line !~ /,[[:space:]]*$/) sub(/[[:space:]]*$/, ",", line);
      print line;
      if (createtext != "") printf "%s", createtext;
      donecreate = 1; next;
    }
    (inld && /^[[:space:]]*"[^"]+":[[:space:]]*\[[[:space:]]*$/) {
      print;
      rk = $0; sub(/^[[:space:]]*"/, "", rk); sub(/":.*/, "", rk);
      if (rk in appmap && !(rk in appdone)) { printf "%s", appmap[rk]; appdone[rk] = 1; }
      next;
    }
    { if (inld && /<\/script>/) inld = 0; print; }
  ' "$target_abs" > "$out"; then
    # added>0 は L411 早期 return で保証済。 awk 後に out==target (byte-identical) =
    # 挿入 anchor (行頭 "@type": / 行末 "key": [) が無く無書き込み = 単一行 JSON-LD 等。
    # 旧実装は無書き込みでも added を返し false-success (folio fix が "materialized N" と報告して
    # 実書込み 0、 #89)。 multi-line に整形すれば挿入可能ゆえ fail-closed (既存 awk-fail と同じ return 1)。
    if cmp -s "$out" "$target_abs"; then
      rm -f "$out" "$create_file" "$append_file"
      echo "folio fix: ${target_rel} の <head> JSON-LD に reverse を挿入できなかった (${added} 件予定、 行頭 \"@type\": / 行末 \"key\": [ の挿入 anchor 不在 — 単一行 JSON-LD 等)。 multi-line に整形して再実行 (fail-closed、 #89)" >&2
      return 1
    fi
    mv "$out" "$target_abs"
    rm -f "$create_file" "$append_file"
    printf '%d' "$added"
    return 0
  else
    rm -f "$out" "$create_file" "$append_file"
    echo "folio fix: awk materialize failed on ${target_rel} (fail-closed)" >&2
    return 1
  fi
}

# folio fix: spec graph を走査し forward A→B (6 dual pair、 B が scan 対象) の reverse B→A を
# target B の <head> JSON-LD に materialize する (REQ-REL-002、 ADR-0025 §2.1)。 idempotent。
# default root = architecture、 --root <dir> で test isolation (validate と対称)。
# exit 0 = success (materialize 実行 or 既に完備) / 2 = tool error (fail-closed)。
folio_cmd_fix() {
  command -v jq >/dev/null 2>&1 || { echo "folio fix: jq not found in PATH (required, fail-closed)" >&2; exit 2; }
  command -v realpath >/dev/null 2>&1 || { echo "folio fix: realpath not found in PATH (required, fail-closed)" >&2; exit 2; }

  local root="architecture"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --root) [[ $# -ge 2 ]] || { echo "folio fix: --root requires a directory argument" >&2; exit 2; }; root="$2"; shift 2 ;;
      --root=*) root="${1#--root=}"; shift ;;
      *) echo "folio fix: unknown argument '$1' (usage: folio fix [--root <dir>])" >&2; exit 2 ;;
    esac
  done
  local root_abs; root_abs=$(realpath -m "$root")
  [[ -d "$root_abs" ]] || { echo "folio fix: root directory not found: ${root} (fail-closed)" >&2; exit 2; }

  # --- Pass 1: 全 scan-target spec の forward を走査し target ごとの owed reverse を集約 ---
  #   owed line = "B_rel \t rev_key \t A_rel" (B=target / A=source、 全 root 相対)。
  #   FolioConstitution / head 無し / scan dir 外の B は folio_is_scan_target で除外 (§2.1 edge case)。
  local dirs=("spec" "decisions" "research") d f
  local owed_lines=""
  for d in "${dirs[@]}"; do
    local dir_abs="${root_abs}/${d}"
    [[ -d "$dir_abs" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      local block a_rel a_subdir
      block=$(folio_extract_head_jsonld "$f")
      [[ -z "$block" ]] && continue
      printf '%s' "$block" | jq -e . >/dev/null 2>&1 || continue
      [[ "$(printf '%s' "$block" | jq -r '."@type" // empty' 2>/dev/null)" == "FolioConstitution" ]] && continue
      a_rel=$(realpath -m --relative-to="$root_abs" "$f")
      a_subdir="${a_rel%%/*}"
      local relmap key resolved rev_key b_rel
      relmap=$(folio_build_relations "$block" "$a_subdir" "$root_abs")
      while IFS=$'\t' read -r key resolved; do
        [[ -z "$key" ]] && continue
        rev_key=$(folio_reverse_of "$key")
        [[ -z "$rev_key" ]] && continue
        case "$resolved" in *:*) continue ;; esac
        b_rel="${resolved%%#*}"
        folio_is_scan_target "${root_abs}/${b_rel}" "$b_rel" || continue
        owed_lines+="${b_rel}"$'\t'"${rev_key}"$'\t'"${a_rel}"$'\n'
      done < <(printf '%s' "$relmap" | jq -r 'to_entries[] | .key as $k | .value[] | "\($k)\t\(.)"' 2>/dev/null)
    done < <(find "$dir_abs" -maxdepth 1 -type f -name '*.html' | LC_ALL=C sort)
  done

  owed_lines=$(printf '%s' "$owed_lines" | LC_ALL=C sort -u)   # (B,rev_key,A) dedup = multi-anchor forward も 1 reverse

  printf 'folio fix — reverse relation materialize + xref auto-wrap (REQ-REL-002 / ADR-0025 / ADR-0034 §2.5)\n'
  printf 'root: %s\n' "$root"

  # --- Pass 2: reverse relation materialize (owed があれば target ごとに、 sort 済で決定的) ---
  local materialized=0 touched=0 b
  if [[ -n "$owed_lines" ]]; then
    while IFS= read -r b; do
      [[ -z "$b" ]] && continue
      local target_abs="${root_abs}/${b}" n rc
      n=$(printf '%s\n' "$owed_lines" | awk -F'\t' -v b="$b" '$1==b{print $2"\t"$3}' \
          | folio_materialize_reverse "$target_abs" "$b" "$root_abs"); rc=$?
      [[ "$rc" -ne 0 ]] && { echo "folio fix: materialize failed for ${b} (fail-closed)" >&2; exit 2; }
      n=${n:-0}
      if [[ "$n" -gt 0 ]]; then
        materialized=$((materialized + n)); touched=$((touched + 1))
        printf '  +%d reverse @id  %s\n' "$n" "$b"
      fi
    done < <(printf '%s\n' "$owed_lines" | awk -F'\t' 'NF>=3{print $1}' | LC_ALL=C sort -u)
  fi

  # --- Pass 3: xref auto-materialize (opt-in doc の prose bare token を <a class="xref"> へ wrap、 ADR-0034 §2.5
  #     option F = 「裸 token → xref 自動 wrap + data-tooltip を定義 essence から生成」)。 wrap_doc が
  #     opt-in (folio-xref-completeness=enabled) 以外は no-op ゆえ、 Slice 1 の real corpus では無作用。 idempotent。 ---
  local xref_wrapped=0 xref_touched=0 xd xf xfrel xn
  for xd in "${dirs[@]}"; do
    local xdir_abs="${root_abs}/${xd}"
    [[ -d "$xdir_abs" ]] || continue
    while IFS= read -r xf; do
      [[ -z "$xf" ]] && continue
      xfrel=$(realpath -m --relative-to="$root_abs" "$xf")
      xn=$(folio_xref_wrap_doc "$xf" "$xfrel" "$root_abs"); xn=${xn:-0}
      if [[ "$xn" -gt 0 ]]; then
        xref_wrapped=$((xref_wrapped + xn)); xref_touched=$((xref_touched + 1))
        printf '  +%d xref       %s\n' "$xn" "$xfrel"
      fi
    done < <(find "$xdir_abs" -maxdepth 1 -type f -name '*.html' | LC_ALL=C sort)
  done

  # --- report (reverse + xref のいずれも 0 なら already-complete) ---
  if [[ "$materialized" -eq 0 && "$xref_wrapped" -eq 0 ]]; then
    printf 'already complete: graph is bidirectional + opt-in xref materialized (0 changes)\n'
  else
    [[ "$materialized" -gt 0 ]] && printf 'materialized %d reverse @id(s) across %d file(s)\n' "$materialized" "$touched"
    [[ "$xref_wrapped" -gt 0 ]] && printf 'materialized %d xref(s) across %d file(s)\n' "$xref_wrapped" "$xref_touched"
  fi
  return 0
}

# ============================================================================
# prose-gate helpers — body markup の deterministic 検査 (WS1、 ADR-0028 §2.2):
#   REQ-CI-014 EARS-coverage (warn) / REQ-CI-015 delta-marker (block) /
#   REQ-CI-013 vocabulary (block、 vocabulary.yaml + yq があれば、 無ければ skip = opt-in)。
#   全て body (</head> 以降) のみ走査。 rules §5/§6 の <pre><code> 例は escaped (&lt;ins /
#   &lt;p) ゆえ実要素 (<ins / <p) に非マッチで自然除外 (head JSON-LD 抽出と同じ idiom)。
# ============================================================================

# </head> 以降の body を stdout に返す。
folio_extract_body() { awk 'b{print} /<\/head>/{b=1}' "$1"; }

# EARS well-formedness (REQ-CI-014、 warn channel): 実 <p class="ears" ...> block が
# (1) data-ears-pattern ∈ 5 pattern (2) class="ears-id" (3) class="ears-shall" を持つか。
# 不備を "rel\t[ears-coverage] ..." 行で stdout (warn = exit code 非影響、 §10.2 warn 設計)。
folio_check_ears() {
  local body="$1" rel="$2"
  printf '%s\n' "$body" | awk -v rel="$rel" '
    function chk(){
      if(!inb){return}; inb=0
      pat=""; if(match(blk,/data-ears-pattern="[^"]*"/)){pat=substr(blk,RSTART,RLENGTH);sub(/^data-ears-pattern="/,"",pat);sub(/"$/,"",pat)}
      valid=" ubiquitous event-driven state-driven optional unwanted "
      if(pat==""){print rel"\t[ears-coverage] ears block に data-ears-pattern 属性が無い"}
      else if(index(valid," "pat" ")==0){print rel"\t[ears-coverage] 不正な data-ears-pattern: "pat}
      if(blk !~ /class="ears-id"/){print rel"\t[ears-coverage] ears block に ears-id span が無い"}
      if(blk !~ /class="ears-shall"/){print rel"\t[ears-coverage] ears block に ears-shall span が無い"}
    }
    /<p class="ears"/{chk(); inb=1; blk=""}
    inb{blk=blk $0 "\n"; if(/<\/p>/){chk()}}
    END{chk()}
  '
}

# 実 <ins/del class="delta" ...> 要素を "tag\tdelta_id\tsuperseded_by" 行で stdout
# (tag=ins|del、 無属性 field は空)。 escaped 例 (&lt;ins) は <ins に非マッチで除外。
folio_extract_delta_elems() {
  local body="$1" el tag id sup
  printf '%s\n' "$body" | grep -oE '<(ins|del) class="delta"[^>]*>' 2>/dev/null | while IFS= read -r el; do
    tag=$(printf '%s' "$el" | grep -oE '^<(ins|del)' | tr -d '<')
    id=$(printf '%s' "$el" | grep -oP 'data-delta-id="\K[^"]*' | head -1)
    sup=$(printf '%s' "$el" | grep -oP 'data-delta-superseded-by="\K[^"]*' | head -1)
    printf '%s\t%s\t%s\n' "$tag" "$id" "$sup"
  done
}

# vocabulary.yaml ($root_abs or その親) の forbidden synonym を 1 行ずつ stdout。
# vocabulary.yaml 不在 or yq 不在なら return 1 (= vocabulary gate を skip、 opt-in)。
# schema: terms: [ { canonical: <name>, forbidden: [ <syn>, ... ] } ] (rules §3、 P-5)。
folio_vocab_forbidden() {
  local root_abs="$1" cand vf=""
  for cand in "${root_abs}/vocabulary.yaml" "$(dirname "$root_abs")/vocabulary.yaml"; do
    [[ -f "$cand" ]] && { vf="$cand"; break; }
  done
  [[ -z "$vf" ]] && return 1
  command -v yq >/dev/null 2>&1 || return 1
  yq -r '.terms[]?.forbidden[]?' "$vf" 2>/dev/null
}

# body から <pre>/<code>/<script>/<style> と machine-readable aside を除去した prose を stdout。
# vocabulary 検査が code 例・機械可読ブロック内の forbidden synonym で誤検出しないため。
folio_prose_only() {
  printf '%s\n' "$1" | awk '
    /<(pre|code|script|style)[ >]/{skip++}
    /<aside class="machine-readable"/{skip++}
    skip==0{print}
    /<\/(pre|code|script|style|aside)>/{if(skip>0)skip--}
  '
}

# dual-audience structural 検査 (REQ-DA-STRUCT-1..5、 ADR-0033 §2.4 / rules.html §7 の floor)。
# co-author dual-audience requirement container (data-audience="human" を担う
# <section class="req">...</section> verbose card と <details class="spec-row">...</details>
# compact row の両 form、 ADR-0033 §2.5 / rules §7.2 2-form) を走査し、
# machine 対応部の存在 (-1) / requirement-id 整合 (-2) / data-audience 値域 (-3) /
# machine 部 aria-hidden 不在 (-4) / EARS-pattern 整合 (-5) を deterministic に検査する。
# 不備を "rel\t[dual-audience] ..." 行で stdout (block gate = exit code 影響)。 意味的 fidelity
# (essence が normative を忠実要約か) は ceiling = spec-review-fidelity agent が別途 LLM 検査する。
# -3 のみ prose (pre/code/aside 除去) を走査し、 ADR 等 prose 内の <code>data-audience=...</code>
# 例示への誤検出を避ける (vocabulary gate と同 idiom)。 -1/-2/-4/-5 は data-audience="human"
# を持つ実 container block (section.req / details.spec-row) を走査するため escaped 例
# (&lt;section / &lt;details) には反応しない。 -5 は CSS class 短縮形
# (req__ears--event/state) を canonical (event-driven/state-driven) に正規化して比較する。
folio_check_dual_audience() {
  local body="$1" rel="$2"
  # -3: data-audience 値域 (machine|human のみ、 REQ-DA-STRUCT-3 / P-5)。 prose_only で code 例示を除外。
  local prose; prose=$(folio_prose_only "$body")
  printf '%s\n' "$prose" | grep -oE 'data-audience="[^"]*"' 2>/dev/null \
    | sed -e 's/^data-audience="//' -e 's/"$//' | LC_ALL=C sort -u | while IFS= read -r val; do
    [[ -z "$val" ]] && continue
    case "$val" in
      machine|human) ;;
      *) printf '%s\t[dual-audience] data-audience 値 "%s" が不正 (machine|human のみ、 REQ-DA-STRUCT-3 / P-5)\n' "$rel" "$val" ;;
    esac
  done
  # -1/-2/-4/-5: 実 dual-audience card (<section class="req"...> ... </section>) を block 走査。
  printf '%s\n' "$body" | awk -v rel="$rel" '
    function chk(   secid, badgeid, earsid, hp, mp, nhp, seg, mtag, idu, bu, eu) {
      if (!inb) return
      inb = 0
      secid = ""
      if (match(blk, /id="[^"]*"/)) { secid = substr(blk, RSTART+4, RLENGTH-5) }
      badgeid = ""
      if (match(blk, /badge--req"[^>]*>[^<]*/)) { seg = substr(blk, RSTART, RLENGTH); sub(/^badge--req"[^>]*>/, "", seg); badgeid = seg }
      earsid = ""
      if (match(blk, /class="ears-id">[^<]*/)) { seg = substr(blk, RSTART, RLENGTH); sub(/^class="ears-id">/, "", seg); earsid = seg }
      gsub(/^[ \t]+|[ \t]+$/, "", badgeid); gsub(/^[ \t]+|[ \t]+$/, "", earsid)
      # -1: machine 対応部の存在 (孤立 human の検出)
      if (blk !~ /data-audience="machine"/) {
        print rel "\t[dual-audience] " (secid != "" ? secid : "(human card)") " に machine 対応部 (data-audience=\"machine\") が無い (孤立 human、 REQ-DA-STRUCT-1)"
      }
      # -2: requirement-id 整合 (case 正規化、 section id <-> badge <-> machine ears-id)
      idu = toupper(secid); bu = toupper(badgeid); eu = toupper(earsid)
      if (secid != "" && badgeid != "" && idu != bu) {
        print rel "\t[dual-audience] requirement-id 不一致: container id \"" secid "\" <-> badge \"" badgeid "\" (REQ-DA-STRUCT-2)"
      }
      if (secid != "" && earsid != "" && idu != eu) {
        print rel "\t[dual-audience] requirement-id 不一致: container id \"" secid "\" <-> machine ears-id \"" earsid "\" (REQ-DA-STRUCT-2)"
      }
      # -4: machine 部 (data-audience="machine" を持つ要素) に aria-hidden 不在
      if (match(blk, /<[^>]*data-audience="machine"[^>]*>/)) {
        mtag = substr(blk, RSTART, RLENGTH)
        if (mtag ~ /aria-hidden/) {
          print rel "\t[dual-audience] machine 部に aria-hidden が付いている (AI/AT から不可視化、 REQ-DA-STRUCT-4)"
        }
      }
      # -5: EARS-pattern 整合 (human badge req__ears--<p> <-> machine data-ears-pattern、 短縮形正規化)
      hp = ""
      if (match(blk, /req__ears--[a-z-]+/)) { hp = substr(blk, RSTART+11, RLENGTH-11) }
      mp = ""
      if (match(blk, /data-ears-pattern="[^"]*"/)) { mp = substr(blk, RSTART+19, RLENGTH-20) }
      nhp = hp
      if (hp == "event") nhp = "event-driven"; else if (hp == "state") nhp = "state-driven"
      if (hp != "" && mp != "" && nhp != mp) {
        print rel "\t[dual-audience] EARS-pattern 不一致: human badge \"" hp "\" <-> machine data-ears-pattern \"" mp "\" (REQ-DA-STRUCT-5)"
      }
    }
    # block 起点 = data-audience="human" を担う requirement container。 container class
    # でなく data-audience semantic で key するため verbose card (section.req) も
    # compact row (details.spec-row) も一律被覆する (ADR-0033 §2.5 / rules §7.2 2-form)。
    # closetag を起点 tag で出し分け、 section.req 内 nested </details> (req__machine) を
    # 誤って block 終端とせず既存被覆を保つ (回帰防止)。
    /<(section|details)[^>]*data-audience="human"/ {
      chk(); inb = 1; blk = ""
      closetag = ($0 ~ /<details[^>]*data-audience="human"/) ? "</details>" : "</section>"
    }
    inb { blk = blk $0 "\n"; if (index($0, closetag)) chk() }
    END { chk() }
  '
}

# ============================================================================
# xref helpers — object cross-reference の横断機構 (ADR-0034 §2.2〜§2.7)。
#   defined-object (principle P-N / requirement REQ-* / decision ADR-NNNN) の
#   class 判定 + prefix→SSoT-doc registry + per-class essence 抽出 + relative href +
#   prose 内 bare-mention 走査を 1 箇所に集約し、 fix (auto-materialize) / validate
#   (4 gate) / inventory・prime (object-graph) の全機能がこの helper 群を共用する
#   (1 entity = 1 機構、 §6 横断機構)。 essence は定義 site の既存内容を再利用し
#   (P-7 重複禁止)、 必ず plain-text 化 + attribute escape する。
# ============================================================================

# canonical token ($1) の class を stdout に返す (principle|requirement|decision、 不該当は空)。
# 採用 token 形は 2-segment REQ (REQ-[A-Z]+-[0-9]+) まで (§2.5、 3-segment は Slice 2a)。
folio_xref_class() {
  case "$1" in
    P-[0-9]*)   [[ "$1" =~ ^P-[0-9]+$ ]] && printf 'principle' ;;
    REQ-[A-Z]*) [[ "$1" =~ ^REQ-[A-Z]+-[0-9]+$ ]] && printf 'requirement' ;;
    ADR-[0-9]*) [[ "$1" =~ ^ADR-[0-9][0-9][0-9][0-9]$ ]] && printf 'decision' ;;
  esac
}

# token ($1) の定義 site anchor を stdout に返す (principle/requirement = 小文字 id、 decision = 空 = file 自体が target)。
folio_xref_anchor() {
  case "$(folio_xref_class "$1")" in
    principle|requirement) printf '%s' "$1" | tr '[:upper:]' '[:lower:]' ;;
    *) printf '' ;;
  esac
}

# token ($1) の SSoT doc を root ($2) 相対 path で stdout に返す (§2.2 registry、 不該当は空)。
# decision は decisions/ADR-NNNN-*.html を glob 解決 (実在時のみ非空)。
folio_xref_ssot() {
  local token="$1" root_abs="$2" n match
  case "$(folio_xref_class "$token")" in
    principle) printf 'spec/constitution.html' ;;
    requirement)
      case "$token" in
        REQ-VER-*) printf 'spec/verification.html' ;;
        REQ-REL-*) printf 'spec/relations.html' ;;
        REQ-CI-*|REQ-DA-*|REQ-CM-*|REQ-ADR-*|REQ-XREF-*) printf 'spec/rules.html' ;;
      esac ;;
    decision)
      n="${token#ADR-}"
      # head へ pipe しない (set -u 下で find|sort|head の $() が空を返す shell quirk 回避)。
      match=$(find "${root_abs}/decisions" -maxdepth 1 -type f -name "ADR-${n}-*.html" 2>/dev/null | LC_ALL=C sort)
      match="${match%%$'\n'*}"
      [[ -n "$match" ]] && realpath -m --relative-to="$root_abs" "$match" ;;
  esac
}

# stdin の HTML 断片を plain-text 化して stdout (内部タグ strip + whitespace collapse + trim)。
folio_xref_plain() {
  sed -e 's/<[^>]*>//g' | tr '\n\t' '  ' | sed -e 's/  */ /g' -e 's/^ *//' -e 's/ *$//'
}

# token ($1) の定義 essence を plain-text で stdout に返す (§6 contract、 既存内容を再利用)。
#   principle  = constitution <dt id="p-N"><strong>P-N: TITLE</strong> の TITLE 部
#   requirement= spec-row <span class="essence"> / verbose card <p class="req__essence"> の text
#   decision   = folio_extract_summary (.meta 末尾セグメント)
# 解決不能 (registry 不該当 / file 不在 / essence 不在) は空文字。
folio_xref_essence() {
  local token="$1" root_abs="$2" ssot file cls lid
  cls=$(folio_xref_class "$token")
  ssot=$(folio_xref_ssot "$token" "$root_abs")
  [[ -z "$ssot" ]] && return 0
  file="${root_abs}/${ssot}"
  [[ -f "$file" ]] || return 0
  case "$cls" in
    principle)
      lid=$(printf '%s' "$token" | tr '[:upper:]' '[:lower:]')
      awk -v id="$lid" '
        index($0,"id=\"" id "\"")>0 {
          if(match($0,/<strong>[^<]*<\/strong>/)){ print substr($0,RSTART+8,RLENGTH-17); exit }
        }' "$file" | sed -E 's/^[A-Z]+-[0-9]+:[[:space:]]*//' | folio_xref_plain
      ;;
    requirement)
      lid=$(printf '%s' "$token" | tr '[:upper:]' '[:lower:]')
      awk -v id="$lid" '
        index($0,"id=\"" id "\"")>0 && /<(details|section)/ && !cap { cap=1; ct=($0 ~ /<details/)?"</details>":"</section>"; buf="" }
        cap { buf=buf $0 "\n"; if(index($0,ct)>0 && !fin){ fin=1 } }
        fin {
          pos=0; endtag=""
          if(match(buf,/class="essence">/)){ pos=RSTART+RLENGTH; endtag="</span>" }
          else if(match(buf,/class="req__essence">/)){ pos=RSTART+RLENGTH; endtag="</p>" }
          if(pos>0){ rest=substr(buf,pos); if(match(rest,endtag)){ print substr(rest,1,RSTART-1) } else { print rest } }
          exit
        }' "$file" | folio_xref_plain
      ;;
    decision)
      folio_extract_summary "$file" | folio_xref_plain
      ;;
  esac
}

# token ($1) の data-tooltip 属性値 (escaped essence) を stdout に返す。 fix (書込) と
# validate tooltip-consistency (検査) が同一関数を呼ぶことで drift 以外の不一致を排除する。
folio_xref_tooltip_text() {
  folio_xref_essence "$1" "$2" | sed -e 's/"/\&quot;/g'
}

# referencing doc ($2 = root 相対 path) から token ($1) の SSoT への relative href を stdout。
# folio_reverse_relid (source=ssot, target_subdir=doc の subdir) を流用し ./foo / ../dir/foo へ正規化。
folio_xref_href() {
  local token="$1" file_rel="$2" root_abs="$3" ssot relid anchor
  ssot=$(folio_xref_ssot "$token" "$root_abs")
  [[ -z "$ssot" ]] && return 1
  relid=$(folio_reverse_relid "$ssot" "${file_rel%%/*}" "$root_abs")
  anchor=$(folio_xref_anchor "$token")
  [[ -n "$anchor" ]] && relid="${relid}#${anchor}"
  printf '%s' "$relid"
}

# xref href ($1) から canonical token を逆算 (anchor=#p-N/#req-... → 大文字化、 ADR file → ADR-NNNN)。
folio_xref_canon_from_href() {
  local href="$1" anchor base
  if [[ "$href" == *"#"* ]]; then
    anchor="${href#*#}"
    case "$anchor" in
      p-[0-9]*|req-*) printf '%s' "$anchor" | tr '[:lower:]' '[:upper:]' ;;
    esac
  else
    base=$(basename "$href")
    [[ "$base" =~ ^(ADR-[0-9][0-9][0-9][0-9])- ]] && printf '%s' "${BASH_REMATCH[1]}"
  fi
}

# file ($1) の <a class="xref"> が指す token 集合 (distinct) を stdout (canon_from_href 経由)。
folio_xref_present_tokens() {
  local file="$1" h tk
  folio_extract_body "$file" | grep -oP '<a [^>]*class="xref"[^>]*>' 2>/dev/null \
    | grep -oP 'href="\K[^"]*' 2>/dev/null | while IFS= read -r h; do
        tk=$(folio_xref_canon_from_href "$h"); [[ -n "$tk" ]] && printf '%s\n' "$tk"
      done | LC_ALL=C sort -u
}

# file ($1) の prose 内 bare-mention token (distinct) を stdout に返す (完全性 / fix 候補の共通源)。
# 除外: code/script/style/machine-readable aside (folio_prose_only) / 見出し h2/h3 / 既存 <a>...</a> 内 /
# 自己定義 token (この doc が id 付き定義 site を持つ object = 自己参照)。 token 形は §2.5 の 3 class。
folio_xref_scan_prose_tokens() {
  local file="$1" body selfdefs
  body=$(folio_extract_body "$file")
  selfdefs=$(folio_prose_only "$body" | grep -oP '\sid="\K(p-[0-9]+|req-[a-z]+-[0-9]+)(?=")' 2>/dev/null \
    | tr '[:lower:]' '[:upper:]' | LC_ALL=C sort -u)
  folio_prose_only "$body" | grep -vP '<h[23][ >]' 2>/dev/null | awk '
    { line=$0; out=""
      while(length(line)>0){
        if(ina){ q=index(line,"</a>"); if(q==0){ line="" } else { line=substr(line,q+4); ina=0 } }
        else { p=index(line,"<a "); if(p==0){ out=out line; line="" } else { out=out substr(line,1,p-1); line=substr(line,p+3); ina=1 } } }
      print out }' \
    | grep -oP '(?<![-0-9A-Za-z])(P-[0-9]+|REQ-[A-Z]+-[0-9]+|ADR-[0-9]{4})(?![-0-9A-Za-z])' 2>/dev/null \
    | LC_ALL=C sort -u | while IFS= read -r tk; do
        [[ -z "$tk" ]] && continue
        printf '%s\n' "$selfdefs" | grep -qxF "$tk" && continue
        printf '%s\n' "$tk"
      done
}

# file ($1=絶対, $2=root 相対, $3=root 絶対) の opt-in doc の prose 内 bare token 初出を
# <a class="xref" href data-tooltip> に wrap する (§2.5 option F materialize)。 wrap 数を stdout。
# opt-in signal = <meta name="folio-xref-completeness" content="enabled"> (無ければ no-op = 0)。
# 既存 xref を持つ token は skip (completeness 充足済・idempotent)、 解決不能 token も skip。
# awk は mask (tag/<a> 領域を space 化) で語境界 + tag/anchor 内除外を判定し初出のみ置換。
folio_xref_wrap_doc() {
  local file="$1" file_rel="$2" root_abs="$3"
  [[ "$(folio_extract_meta "$file" folio-xref-completeness)" == "enabled" ]] || { printf '0'; return 0; }

  local present mapfile tk href tip cand=0
  present=$(folio_xref_present_tokens "$file")
  mapfile=$(mktemp)
  while IFS= read -r tk; do
    [[ -z "$tk" ]] && continue
    printf '%s\n' "$present" | grep -qxF "$tk" && continue
    href=$(folio_xref_href "$tk" "$file_rel" "$root_abs") || continue
    [[ -z "$href" ]] && continue
    tip=$(folio_xref_tooltip_text "$tk" "$root_abs")
    [[ -z "$tip" ]] && continue
    printf '%s\t%s\t%s\n' "$tk" "$href" "$tip" >> "$mapfile"
    cand=$((cand + 1))
  done < <(folio_xref_scan_prose_tokens "$file")
  if [[ "$cand" -eq 0 ]]; then rm -f "$mapfile"; printf '0'; return 0; fi

  local before after out
  before=$(grep -o 'class="xref"' "$file" 2>/dev/null | wc -l)   # occurrence 数 (同一行複数 xref に対応、 grep -c は行数で誤る)
  out=$(mktemp)
  awk -v mapfile="$mapfile" '
    BEGIN{ nt=0
      while((getline l < mapfile)>0){ m=split(l,a,"\t"); if(m>=3){ nt++; toks[nt]=a[1]; href[a[1]]=a[2]; tip[a[1]]=a[3]; wrapped[a[1]]=0 } }
      ANC=0; skip=0 }
    function isword(ch){ return (ch ~ /[-0-9A-Za-z]/) }
    function build_mask(s,   i,c,mk){
      mk=""
      for(i=1;i<=length(s);i++){
        c=substr(s,i,1)
        if(ANC){ mk=mk " "; if(c==">" && substr(s,i-3,4)=="</a>") ANC=0; continue }
        if(intag){ mk=mk " "; if(c==">") intag=0; continue }
        if(c=="<"){ if(substr(s,i,3)=="<a " || substr(s,i,3)=="<a>"){ ANC=1 } else { intag=1 } mk=mk " "; continue }
        mk=mk c
      }
      return mk
    }
    { line=$0
      openskip = (line ~ /<(pre|code|script|style)[ >]/) || (line ~ /<aside class="machine-readable"/)
      if(openskip) skip++
      wrappable = (skip==0) && (line !~ /<h[23][ >]/)
      anc_in=ANC; intag=0
      if(wrappable){
        for(ti=1; ti<=nt; ti++){
          tk=toks[ti]; if(wrapped[tk]) continue
          ANC=anc_in; intag=0; mk=build_mask(line)
          start=1
          while(1){
            sub_mk=substr(mk,start); p=index(sub_mk,tk); if(p==0) break
            p=p+start-1
            before=(p>1)?substr(mk,p-1,1):""
            after=substr(mk,p+length(tk),1)
            if((before=="" || !isword(before)) && (after=="" || !isword(after))){
              anc="<a class=\"xref\" href=\"" href[tk] "\" data-tooltip=\"" tip[tk] "\">" tk "</a>"
              line=substr(line,1,p-1) anc substr(line,p+length(tk))
              wrapped[tk]=1; break
            }
            start=p+length(tk)
          }
        }
      }
      ANC=anc_in; intag=0; build_mask(line)   # 最終 line で ANC を次行へ正しく carry
      if(line ~ /<\/(pre|code|script|style|aside)>/){ if(skip>0) skip-- }
      print line
    }
  ' "$file" > "$out"

  if cmp -s "$out" "$file"; then rm -f "$out" "$mapfile"; printf '0'; return 0; fi
  mv "$out" "$file"
  after=$(grep -o 'class="xref"' "$file" 2>/dev/null | wc -l)
  rm -f "$mapfile"
  printf '%d' "$((after - before))"
}

# corpus ($1=root 絶対) を走査し canonical id (p-N / req-...) が 2 site 以上で定義される
# = uniqueness violation を "(corpus)\t[xref-uniqueness] ..." 行で stdout (§2.6)。 prose_only で
# code 例 (rules §7.2 の id="req-xxx-001" 等) を除外し誤検出を防ぐ。 重複なしは無出力。
folio_xref_uniqueness_check() {
  local root_abs="$1" d f rel tmp cid count files up
  tmp=$(mktemp)
  for d in spec decisions research; do
    local dir_abs="${root_abs}/${d}"
    [[ -d "$dir_abs" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      rel=$(realpath -m --relative-to="$root_abs" "$f")
      folio_prose_only "$(folio_extract_body "$f")" | grep -oP '\sid="\K(p-[0-9]+|req-[a-z]+-[0-9]+)(?=")' 2>/dev/null \
        | while IFS= read -r cid; do [[ -n "$cid" ]] && printf '%s\t%s\n' "$cid" "$rel"; done
    done < <(find "$dir_abs" -maxdepth 1 -type f -name '*.html' | LC_ALL=C sort)
  done > "$tmp"
  while IFS= read -r cid; do
    [[ -z "$cid" ]] && continue
    count=$(awk -F'\t' -v c="$cid" '$1==c{n++} END{print n+0}' "$tmp")
    if [[ "$count" -ge 2 ]]; then
      files=$(awk -F'\t' -v c="$cid" '$1==c{print $2}' "$tmp" | LC_ALL=C sort -u | tr '\n' ' ' | sed 's/ *$//')
      up=$(printf '%s' "$cid" | tr '[:lower:]' '[:upper:]')
      printf '%s\t[xref-uniqueness] %s が複数の SSoT 定義 site を持つ (%s、 ADR-0034 §2.6)\n' "(corpus)" "$up" "$files"
    fi
  done < <(cut -f1 "$tmp" | LC_ALL=C sort -u)
  rm -f "$tmp"
}

# corpus ($1=root 絶対) の object-graph (nodes + edges) を JSON で stdout に返す (§2.7 projection)。
#   nodes = canonical object (principle: constitution / requirement: id 付き spec-row・card /
#           decision: ADR file)、 各 {id, class, ssot, essence}。 essence は §6 helper を再利用。
#   edges = in-band <a class="xref"> 集計 {from(doc), to(token)}。 Slice 1 corpus は概ね空。
# 決定的: nodes は id+ssot で sort、 edges は from+to で sort+unique、 timestamp 非含有。
folio_xref_build_objectgraph() {
  local root_abs="$1" d f rel subdir body nodes_tsv edges_tsv
  nodes_tsv=$(mktemp); edges_tsv=$(mktemp)

  # principle nodes (constitution は spec graph scan 外だが canonical object)
  local consti="${root_abs}/spec/constitution.html" pid ptok pess
  if [[ -f "$consti" ]]; then
    while IFS= read -r pid; do
      [[ -z "$pid" ]] && continue
      ptok=$(printf '%s' "$pid" | tr '[:lower:]' '[:upper:]')
      pess=$(folio_xref_essence "$ptok" "$root_abs")
      printf '%s\t%s\t%s\t%s\n' "$ptok" "principle" "spec/constitution.html#${pid}" "$pess" >> "$nodes_tsv"
    done < <(folio_prose_only "$(folio_extract_body "$consti")" | grep -oP '\sid="\K(p-[0-9]+)(?=")' 2>/dev/null | LC_ALL=C sort -u)
  fi

  for d in spec decisions research; do
    local dir_abs="${root_abs}/${d}"
    [[ -d "$dir_abs" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      rel=$(realpath -m --relative-to="$root_abs" "$f"); subdir="${rel%%/*}"
      body=$(folio_extract_body "$f")
      local rid rtok ress
      while IFS= read -r rid; do
        [[ -z "$rid" ]] && continue
        rtok=$(printf '%s' "$rid" | tr '[:lower:]' '[:upper:]')
        ress=$(folio_xref_essence "$rtok" "$root_abs")
        printf '%s\t%s\t%s\t%s\n' "$rtok" "requirement" "${rel}#${rid}" "$ress" >> "$nodes_tsv"
      done < <(folio_prose_only "$body" | grep -oP '\sid="\K(req-[a-z]+-[0-9]+)(?=")' 2>/dev/null | LC_ALL=C sort -u)
      if [[ "$subdir" == "decisions" ]]; then
        local adrid aess
        adrid=$(basename "$f" | grep -oP '^ADR-[0-9]{4}')
        if [[ -n "$adrid" ]]; then
          aess=$(folio_extract_summary "$f" | folio_xref_plain)
          printf '%s\t%s\t%s\t%s\n' "$adrid" "decision" "$rel" "$aess" >> "$nodes_tsv"
        fi
      fi
      local eh etok
      while IFS= read -r eh; do
        [[ -z "$eh" ]] && continue
        etok=$(folio_xref_canon_from_href "$eh"); [[ -z "$etok" ]] && continue
        printf '%s\t%s\n' "$rel" "$etok" >> "$edges_tsv"
      done < <(printf '%s\n' "$body" | grep -oP '<a [^>]*class="xref"[^>]*>' 2>/dev/null | grep -oP 'href="\K[^"]*' 2>/dev/null)
    done < <(find "$dir_abs" -maxdepth 1 -type f -name '*.html' | LC_ALL=C sort)
  done

  local nodes_json edges_json
  nodes_json=$(jq -R -s 'split("\n")|map(select(length>0)|split("\t")|{id:.[0],class:.[1],ssot:.[2],essence:.[3]})|sort_by(.id,.ssot)' "$nodes_tsv")
  edges_json=$(jq -R -s 'split("\n")|map(select(length>0)|split("\t")|{from:.[0],to:.[1]})|unique|sort_by(.from,.to)' "$edges_tsv")
  rm -f "$nodes_tsv" "$edges_tsv"
  jq -n --argjson nodes "$nodes_json" --argjson edges "$edges_json" '{nodes:$nodes,edges:$edges}'
}

# ============================================================================
# validate helpers — spec 集合の internal link-integrity + jsonld structural +
# broken-reverse 検査 (REQ-VER-013/015、 ADR-0020 を ADR-0025 で 3-gate に拡張)。
# jsonld 構造 check は plugin-lib.sh を共用 (§2.4 DRY)、 link-integrity + broken-reverse は
# 本 file の resolve/build_relations + bidirectional helpers を検査 root 注入で再利用する。
# ============================================================================

# folio validate: spec 集合 (root/{spec,decisions,research} の <head> JSON-LD .html) を
# 横断し 3 gate を検査する (REQ-VER-013/015、 ADR-0020 §2.1 を ADR-0025 §2.2 で 3-gate 化):
#   (a) internal link-integrity — JSON-LD relation @id を resolve → target file 存在 +
#       #anchor は target 内 id 存在 (REQ-CI-010 (b)+(c))
#   (b) jsonld structural — plugin-lib.sh の folio_jsonld_structural_check を共用
#       (parse + @context/@id/@type + @context==object、 REQ-CI-016、 ADR-0004 Option B Light)
#   (c) broken-reverse — forward (§5.1 の 6 dual pair) A→B で B が scan 対象なのに reverse B→A
#       が欠ける場合 violation (REQ-REL-004、 fix = folio_cmd_fix と detect↔remediate 対)
# default root = architecture、 --root <dir> で検査 root を override する (test isolation、 §2.3 MUST)。
# external URL check と prose gate は試作 scope 外 (§2.2、 Phase X4+)。
# exit 0=clean / 1=violation 検出 / 2=tool error (jq 不在・root 不在等、 fail-closed)。
folio_cmd_validate() {
  # 構造 check 共有関数を plugin-lib.sh から読む (ADR-0020 §2.4 DRY)。 validate のみが
  # 依存するため lazy source (version/help/inventory/prime は plugin-lib 非依存のまま維持)。
  source "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../scripts/plugin-lib.sh" \
    || { echo "folio validate: cannot load plugin-lib.sh (fail-closed)" >&2; exit 2; }

  command -v jq >/dev/null 2>&1 || { echo "folio validate: jq not found in PATH (required, fail-closed)" >&2; exit 2; }

  # --- arg parse: --root <dir> (default architecture) ---
  local root="architecture"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --root)
        [[ $# -ge 2 ]] || { echo "folio validate: --root requires a directory argument" >&2; exit 2; }
        root="$2"; shift 2 ;;
      --root=*) root="${1#--root=}"; shift ;;
      *) echo "folio validate: unknown argument '$1' (usage: folio validate [--root <dir>])" >&2; exit 2 ;;
    esac
  done

  local root_abs
  root_abs=$(realpath -m "$root")
  [[ -d "$root_abs" ]] || { echo "folio validate: root directory not found: ${root} (fail-closed)" >&2; exit 2; }

  # --- 横断検査: spec/decisions/research のうち存在する dir のみ (検査 root の最小構成許容) ---
  # FolioConstitution schema の constitution は @type で schema-based に skip (inventory と同基準、 名前非依存、 ADR-0023 / ADR-0024 §2.2) ---
  local dirs=("spec" "decisions" "research") d f
  local files_checked=0 relations_checked=0 link_fail=0 struct_fail=0 revlink_fail=0
  local vocab_fail=0 delta_fail=0 ears_warn=0 da_fail=0
  # xref gate flags (ADR-0034 §2.6): resolve/uniqueness/tooltip = universal、 completeness = opt-in
  local xref_resolve_fail=0 xref_uniq_fail=0 xref_tooltip_fail=0 xref_complete_fail=0 xref_complete_seen=0
  local violations=() warnings=() delta_records=() delta_ids=()
  # vocabulary forbidden synonym list (opt-in: vocabulary.yaml + yq、 無ければ空 = gate skip)
  local vocab_list; vocab_list=$(folio_vocab_forbidden "$root_abs") || vocab_list=""

  for d in "${dirs[@]}"; do
    local dir_abs="${root_abs}/${d}"
    [[ -d "$dir_abs" ]] || continue
    while IFS= read -r f; do
      [[ -z "$f" ]] && continue
      local block rel subdir reason
      block=$(folio_extract_head_jsonld "$f")
      [[ -z "$block" ]] && continue          # JSON-LD 無し = scan 対象外 (relations.html §4.4.1 と同基準)
      # FolioConstitution schema = 不変 anchor、 scan 除外 (inventory build_entry と同基準、 @type で schema-based)
      [[ "$(printf '%s' "$block" | jq -r '."@type" // empty' 2>/dev/null)" == "FolioConstitution" ]] && continue
      files_checked=$((files_checked + 1))
      rel=$(realpath -m --relative-to="$root_abs" "$f")   # 例 spec/relations.html (決定的・root 相対)
      subdir="${rel%%/*}"

      # gate (b) jsonld structural (共有関数、 short-circuit で最初の 1 件)
      if ! reason=$(folio_jsonld_structural_check "$block"); then
        violations+=("${rel}"$'\t'"[jsonld-structural] ${reason}")
        struct_fail=1
      fi

      # gate (a) internal link-integrity — block が parse 可能な時のみ relation 抽出
      printf '%s' "$block" | jq -e . >/dev/null 2>&1 || continue
      local relmap key resolved pathpart anchor target_abs rev_key
      relmap=$(folio_build_relations "$block" "$subdir" "$root_abs")
      while IFS=$'\t' read -r key resolved; do
        [[ -z "$key" ]] && continue
        # external URL (resolved が ':' を含む = scheme) は試作 scope 外で skip (ADR-0020 §2.2、 X4+)。
        # 正規 relpath は ':' を含まない (realpath は scheme の '//' を '/' に潰すが ':' は残る)。
        case "$resolved" in *:*) continue ;; esac
        relations_checked=$((relations_checked + 1))
        if [[ "$resolved" == *"#"* ]]; then
          pathpart="${resolved%%#*}"; anchor="${resolved#*#}"
        else
          pathpart="$resolved"; anchor=""
        fi
        target_abs="${root_abs}/${pathpart}"
        if [[ ! -f "$target_abs" ]]; then
          violations+=("${rel}"$'\t'"[link-missing-file] ${key} -> ${pathpart} (target file not found)")
          link_fail=1
        elif [[ -n "$anchor" ]]; then
          # anchor = target file 内の HTML 要素 id="..."/'...' 存在を確認 (grep -F = 固定文字列)。
          # 試作 heuristic: data-*-id 等への substring 誤一致は理論上あり得るが、 折り目正しい
          # folio spec の id naming (sN-...) では非衝突。 精緻な id parse は完成形 (ADR-0004 ajv/pyld)。
          if ! grep -qF "id=\"${anchor}\"" "$target_abs" && ! grep -qF "id='${anchor}'" "$target_abs"; then
            violations+=("${rel}"$'\t'"[link-broken-anchor] ${key} -> ${pathpart}#${anchor} (anchor id not found in target)")
            link_fail=1
          fi
        fi

        # gate (c) broken-reverse — forward (6 dual pair) A→B で B が scan 対象なのに reverse
        # B→A が欠ける場合 violation (REQ-REL-004、 ADR-0025 §2.2)。 fix (folio_cmd_fix) と同一の
        # scan-target 判定 + reverse 探索を共用し detect↔remediate が対をなす (fix 後は clean)。
        # B が非 scan 対象 (constitution / head 無し / scan dir 外 / 不在 file) なら reverse 不要。
        rev_key=$(folio_reverse_of "$key")
        if [[ -n "$rev_key" ]] && folio_is_scan_target "$target_abs" "$pathpart"; then
          if ! folio_target_has_reverse "$target_abs" "${pathpart%%/*}" "$rev_key" "$rel" "$root_abs"; then
            violations+=("${rel}"$'\t'"[broken-reverse] ${key} -> ${pathpart} (target missing reverse ${rev_key} back to ${rel})")
            revlink_fail=1
          fi
        fi
      done < <(printf '%s' "$relmap" | jq -r 'to_entries[] | .key as $k | .value[] | "\($k)\t\(.)"' 2>/dev/null)

      # --- body prose gates (WS1、 ADR-0028 §2.2: ears warn / delta block / vocabulary block) ---
      local body; body=$(folio_extract_body "$f")
      # gate (e) EARS-coverage — warn channel (exit code 非影響、 REQ-CI-014)
      local ew
      while IFS= read -r ew; do [[ -n "$ew" ]] && { warnings+=("$ew"); ears_warn=1; }; done < <(folio_check_ears "$body" "$rel")
      # gate (f) delta-marker — 要素を収集 (format + 解決 check は全 file 走査後、 REQ-CI-015)
      local dtag did dsup
      while IFS=$'\t' read -r dtag did dsup; do
        [[ -z "$dtag" ]] && continue
        delta_records+=("${rel}"$'\t'"${dtag}"$'\t'"${did}"$'\t'"${dsup}")
        [[ -n "$did" ]] && delta_ids+=("$did")
      done < <(folio_extract_delta_elems "$body")
      # gate (d) vocabulary — forbidden synonym 検出 (block、 opt-in、 REQ-CI-013)
      if [[ -n "$vocab_list" ]]; then
        local prose syn
        prose=$(folio_prose_only "$body")
        while IFS= read -r syn; do
          [[ -z "$syn" ]] && continue
          if printf '%s' "$prose" | grep -qF "$syn"; then
            violations+=("${rel}"$'\t'"[vocabulary] forbidden synonym '${syn}' を検出 (P-5: canonical 名を使用)")
            vocab_fail=1
          fi
        done <<< "$vocab_list"
      fi
      # gate (g) dual-audience structural — block (REQ-DA-STRUCT-1..5、 ADR-0033、 rules §7 floor)
      local dav
      while IFS= read -r dav; do [[ -n "$dav" ]] && { violations+=("$dav"); da_fail=1; }; done < <(folio_check_dual_audience "$body" "$rel")

      # --- xref gates (ADR-0034 §2.6): resolve/tooltip = universal、 completeness = opt-in meta ---
      # gate (h) xref resolve-integrity — body の <a class="xref" href> が定義 site に解決するか。
      # Slice 1 の real corpus は xref link を概ね持たないため検査対象ゼロで clean (dogfood は Slice 2b)。
      local xhref xres xpath xanchor xtarget
      while IFS= read -r xhref; do
        [[ -z "$xhref" ]] && continue
        case "$xhref" in *:*) continue ;; esac    # external (xref では稀) は試作 scope 外 skip
        xres=$(folio_resolve_relpath "$xhref" "$subdir" "$root_abs")
        if [[ "$xres" == *"#"* ]]; then xpath="${xres%%#*}"; xanchor="${xres#*#}"; else xpath="$xres"; xanchor=""; fi
        xtarget="${root_abs}/${xpath}"
        if [[ ! -f "$xtarget" ]]; then
          violations+=("${rel}"$'\t'"[xref-broken] class=xref -> ${xpath} (xref target file not found)"); xref_resolve_fail=1
        elif [[ -n "$xanchor" ]] && ! grep -qF "id=\"${xanchor}\"" "$xtarget" && ! grep -qF "id='${xanchor}'" "$xtarget"; then
          violations+=("${rel}"$'\t'"[xref-broken] class=xref -> ${xpath}#${xanchor} (xref anchor id not found in target)"); xref_resolve_fail=1
        fi
      done < <(printf '%s\n' "$body" | grep -oP '<a [^>]*class="xref"[^>]*>' 2>/dev/null | grep -oP 'href="\K[^"]*' 2>/dev/null)

      # gate (i) xref tooltip-consistency — cached data-tooltip が定義の現 essence と一致するか
      # (drift 検出、 fix 再生成 = §2.4 no-JS 複製の managed staleness)。 fix と同一 folio_xref_tooltip_text。
      local xtag xh xtip xtok xexp
      while IFS= read -r xtag; do
        [[ -z "$xtag" ]] && continue
        printf '%s' "$xtag" | grep -q 'data-tooltip=' || continue
        xh=$(printf '%s' "$xtag" | grep -oP 'href="\K[^"]*')
        xtip=$(printf '%s' "$xtag" | grep -oP 'data-tooltip="\K[^"]*')
        xtok=$(folio_xref_canon_from_href "$xh"); [[ -z "$xtok" ]] && continue
        xexp=$(folio_xref_tooltip_text "$xtok" "$root_abs")
        [[ -z "$xexp" ]] && continue   # 解決不能 token (essence 空) は resolve gate の責務、 tooltip では二重報告しない
        if [[ "$xtip" != "$xexp" ]]; then
          violations+=("${rel}"$'\t'"[xref-stale-tooltip] ${xtok} data-tooltip drifted from current essence (fix で再生成)"); xref_tooltip_fail=1
        fi
      done < <(printf '%s\n' "$body" | grep -oP '<a [^>]*class="xref"[^>]*>' 2>/dev/null)

      # gate (j) xref completeness — orphan-mention (opt-in: folio-xref-completeness=enabled の doc のみ)。
      # Slice 1 では誰も opt-in しないため real corpus で no-op (KEYSTONE invariant、 ADR-0034 §2.5/§2.6)。
      if [[ "$(folio_extract_meta "$f" folio-xref-completeness)" == "enabled" ]]; then
        xref_complete_seen=1
        local present_t bare_t
        present_t=$(folio_xref_present_tokens "$f")
        while IFS= read -r bare_t; do
          [[ -z "$bare_t" ]] && continue
          printf '%s\n' "$present_t" | grep -qxF "$bare_t" && continue
          violations+=("${rel}"$'\t'"[xref-orphan-mention] ${bare_t} prose で言及されるが resolvable xref が無い (completeness、 fix で wrap)"); xref_complete_fail=1
        done < <(folio_xref_scan_prose_tokens "$f")
      fi
    done < <(find "$dir_abs" -maxdepth 1 -type f -name '*.html' | LC_ALL=C sort)
  done

  # --- gate (k) xref uniqueness — canonical id が corpus 全体で 2 site 以上定義されていないか (ADR-0034 §2.6) ---
  # prose_only で code 例 (rules §7.2 の id="req-xxx-001" 等) を除外し誤検出を防ぐ。 重複は normalization
  # (Slice 2a) 前の real corpus には無いため clean。 重複が見つかった場合のみ block する設計。
  local uline
  while IFS= read -r uline; do
    [[ -z "$uline" ]] && continue
    violations+=("$uline"); xref_uniq_fail=1
  done < <(folio_xref_uniqueness_check "$root_abs")

  # --- gate (f) delta-marker resolution (REQ-CI-015、 全 file 走査後に format + 解決 check) ---
  local idset dr drel dtag2 did2 dsup2
  idset=" $(printf '%s ' "${delta_ids[@]+"${delta_ids[@]}"}")"
  for dr in "${delta_records[@]+"${delta_records[@]}"}"; do
    IFS=$'\t' read -r drel dtag2 did2 dsup2 <<< "$dr"
    if [[ -z "$did2" ]]; then
      violations+=("${drel}"$'\t'"[delta-marker] <${dtag2} class=delta> に data-delta-id が無い"); delta_fail=1; continue
    fi
    if ! [[ "$did2" =~ ^D-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$ ]]; then
      violations+=("${drel}"$'\t'"[delta-marker] data-delta-id '${did2}' が D-YYYY-MM-DD-NNN format でない"); delta_fail=1
    fi
    if [[ "$dtag2" == "del" ]]; then
      if [[ -z "$dsup2" ]]; then
        violations+=("${drel}"$'\t'"[delta-marker] <del> '${did2}' に data-delta-superseded-by が無い"); delta_fail=1
      elif [[ "$idset" != *" ${dsup2} "* ]]; then
        violations+=("${drel}"$'\t'"[delta-marker] data-delta-superseded-by '${dsup2}' が既存 delta-id に解決しない"); delta_fail=1
      fi
    fi
  done

  # --- report (stdout、 決定的: counts + per-gate status + sort 済 violation 列) ---
  printf 'folio validate — link-integrity + jsonld + broken-reverse + vocabulary + delta-marker + ears-coverage + dual-audience + xref (ADR-0020/0025/0028/0033/0034)\n'
  printf 'root: %s\n' "$root"
  printf 'files checked: %d · relations checked: %d\n' "$files_checked" "$relations_checked"

  # per-gate status は fail flag から一意に導出 (clean なら全 [OK])。 clean/violation 分岐で
  # 重複させず、 「clean ⟹ 全 gate OK」 の不変条件を出力構造に持たせる (review R2 反映)。
  if [[ "$link_fail" -eq 1 ]]; then printf '  [FAIL] internal link-integrity\n'; else printf '  [OK] internal link-integrity\n'; fi
  if [[ "$struct_fail" -eq 1 ]]; then printf '  [FAIL] jsonld structural\n'; else printf '  [OK] jsonld structural\n'; fi
  if [[ "$revlink_fail" -eq 1 ]]; then printf '  [FAIL] broken-reverse\n'; else printf '  [OK] broken-reverse\n'; fi
  if [[ -z "$vocab_list" ]]; then printf '  [SKIP] vocabulary (vocabulary.yaml 無し = opt-in)\n'
  elif [[ "$vocab_fail" -eq 1 ]]; then printf '  [FAIL] vocabulary\n'; else printf '  [OK] vocabulary\n'; fi
  if [[ "$delta_fail" -eq 1 ]]; then printf '  [FAIL] delta-marker\n'; else printf '  [OK] delta-marker\n'; fi
  if [[ "$da_fail" -eq 1 ]]; then printf '  [FAIL] dual-audience-structural\n'; else printf '  [OK] dual-audience-structural\n'; fi
  if [[ "$xref_resolve_fail" -eq 1 ]]; then printf '  [FAIL] xref-resolve\n'; else printf '  [OK] xref-resolve\n'; fi
  if [[ "$xref_uniq_fail" -eq 1 ]]; then printf '  [FAIL] xref-uniqueness\n'; else printf '  [OK] xref-uniqueness\n'; fi
  if [[ "$xref_tooltip_fail" -eq 1 ]]; then printf '  [FAIL] xref-tooltip-consistency\n'; else printf '  [OK] xref-tooltip-consistency\n'; fi
  if [[ "$xref_complete_seen" -eq 0 ]]; then printf '  [SKIP] xref-completeness (folio-xref-completeness=enabled doc 無し = opt-in)\n'
  elif [[ "$xref_complete_fail" -eq 1 ]]; then printf '  [FAIL] xref-completeness\n'; else printf '  [OK] xref-completeness\n'; fi
  if [[ "$ears_warn" -eq 1 ]]; then printf '  [WARN] ears-coverage\n'; else printf '  [OK] ears-coverage\n'; fi

  # warn channel (REQ-CI-014 EARS-coverage は warn = exit code 非影響、 §10.2 warn 設計)
  if [[ ${#warnings[@]} -gt 0 ]]; then
    printf '\nwarnings (%d):\n' "${#warnings[@]}"
    printf '%s\n' "${warnings[@]}" | LC_ALL=C sort | while IFS=$'\t' read -r wfile wdetail; do
      printf '  %s %s\n' "$wfile" "$wdetail"
    done
  fi

  # clean / violation は最終ブロック + exit code のみ分岐 (block gate violation のみ exit 1、 warn は不問)
  if [[ ${#violations[@]} -eq 0 ]]; then
    printf '\nclean: 0 violations\n'
    return 0
  fi

  printf '\nviolations (%d):\n' "${#violations[@]}"
  printf '%s\n' "${violations[@]}" | LC_ALL=C sort | while IFS=$'\t' read -r vfile vdetail; do
    printf '  %s %s\n' "$vfile" "$vdetail"
  done
  return 1
}

# ============================================================================
# init helpers — consumer canonical layout を scaffold (REQ-VER-014、 ADR-0024)
#   生成物 = 純粋な構造のみ (ADR-0031 が ADR-0024 §2.1 seed を revise): architecture/{spec,
#   decisions,research} の cluster README (P-6 entry point) + folio.config.yaml (§2.5 defaults)。
#   spec/{constitution,overview}.html の本文 (実体) は seed しない — folio-architect の greenfield
#   onboarding grilling が中身を引き出した時のみ lazy-materialize する (folio-self-spec §7.1、 ADR-0031)。
#   spec/README は実在 file のみ dc:hasPart 宣言する (生成直後は part 無し)。 空 placeholder を残さず
#   whisper の hollow-constitution を構造的に排除。 test dir は scaffold しない (ADR-0026: consumer の
#   (b) 実装適合性 test は stack 慣習 (tests/ 等) に置き folio は規定しない、 P-13(b))。
#   idempotent (§2.3): 既存 file は preserve (上書き禁止)、 欠損のみ生成。
#   生成 skeleton (3 cluster README + config) は全 conforming JSON-LD かつ relation 0 のため folio
#   validate が clean (exit 0)。 exit 0=success / 2=tool error (fail-closed)。 assets/ や CLAUDE.md/
#   README.md は生成しない (§2.1)。
# ============================================================================

# 1 seed file を idempotent に生成。 $1 = 生成先絶対 path、 $2 = 報告用 relative base (target dir)。
# 内容は stdin (heredoc) から読む。 既存なら preserve して "exists" 報告、 欠損なら mkdir + 生成して
# "create" 報告 (target 相対 path)。 write 失敗時のみ return 1 (caller が exit 2、 fail-closed)。
folio_init_write() {
  local dest="$1" base="$2" rel
  rel=$(realpath -m --relative-to="$base" "$dest")
  if [[ -e "$dest" ]]; then
    printf 'exists  %s\n' "$rel"
    return 0
  fi
  mkdir -p "$(dirname "$dest")" || return 1
  cat > "$dest" || return 1            # stdin → file (heredoc bytes を厳密保持、 trailing newline 込み)
  printf 'create  %s\n' "$rel"
}

# folio init [<dir>]: consumer canonical layout を <dir> (省略時 cwd) に scaffold (REQ-VER-014)。
# 既存 file を preserve しつつ欠損 seed のみ生成し、 per-file の create/exists を stdout 報告する。
folio_cmd_init() {
  command -v realpath >/dev/null 2>&1 || { echo "folio init: realpath not found in PATH (required, fail-closed)" >&2; exit 2; }

  local target arch
  target=$(realpath -m "${1:-.}")
  arch="${target}/architecture"

  mkdir -p "$target" || { echo "folio init: cannot create target directory: ${target} (fail-closed)" >&2; exit 2; }
  echo "folio init: scaffolding consumer canonical layout at ${target}"

  local rc=0

  # --- folio.config.yaml (§2.5 defaults、 P-2 YAML 例外) ---
  folio_init_write "${target}/folio.config.yaml" "$target" <<'YAML' || rc=1
folio_version: "^0.5"
spec_path: "architecture/spec/"
caller_marker_env: "FOLIO_ARCHITECT_CONTEXT"
caller_marker_value: "folio-architect"
review_model: "opus"
YAML

  # --- architecture/spec/ (design-intent WHAT cluster、 P-7) ---
  folio_init_write "${arch}/spec/README.html" "$target" <<'HTML' || rc=1
<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="folio-doc-type" content="cluster-readme">
<meta name="folio-layer" content="project">
<meta name="folio-version" content="0.1.0-draft">
<meta name="folio-status" content="active">
<meta name="folio-stakeholders" content="Developer, AI Agent">
<title>architecture/spec/ — spec index</title>
<link rel="stylesheet" href="../../common.css">
<script type="application/ld+json">
{
  "@context": {
    "dc": "http://purl.org/dc/terms/",
    "schema": "https://schema.org/",
    "folio": "https://folio.dev/spec/v1/"
  },
  "@id": "./README.html",
  "@type": "schema:TechArticle",
  "dc:title": "spec cluster index",
  "folio:version": "0.1.0-draft"
}
</script>
</head>
<body>

<header class="doc-header">
  <h1>architecture/spec/ — spec index</h1>
  <div class="meta">v0.1.0-draft &middot; status: active &middot; project design-intent (WHAT) cluster の entry point</div>
</header>

<aside class="informative">
<p>本 dir (<code>architecture/spec/</code>) はこの project の <strong>design-intent spec</strong> (構造・不変条件・WHAT) を集約する cluster です。 spec file は <a href="https://folio.dev/">folio</a> framework の rules に従い HTML + JSON-LD で記述します。 共通 stylesheet (<code>common.css</code>) は project root に任意で配置してください。</p>
</aside>

<section id="s1-purpose" class="informative">
<h2>§1. Purpose</h2>
<p>本 README は <strong>spec/ cluster の index</strong> (entry point) です。 cluster 内の spec を一望し、 reader (人間 / AI agent) のナビゲーションを支えます。</p>
</section>

<section id="s2-contents" class="informative">
<h2>§2. Contents</h2>
<p>この cluster はまだ spec を含みません。 spec は <code>folio-architect</code> の onboarding grilling (greenfield) が中身を引き出した時点で lazy に作成されます — 通常はまず <code>constitution.html</code> (この project 固有の不変原則) と <code>overview.html</code> (architecture の俯瞰) が authored されます。 空の placeholder は意図的に置きません (hollow-spec 防止)。</p>
<p>spec を追加したら、 本 README の <code>dc:hasPart</code> と本 §2 に<strong>実在 file のみ</strong>追記してください。</p>
</section>

</body>
</html>
HTML

  # --- architecture/decisions/ (decision WHY cluster、 P-7) ---
  folio_init_write "${arch}/decisions/README.html" "$target" <<'HTML' || rc=1
