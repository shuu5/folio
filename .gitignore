# OS / editor
.DS_Store
*.swp
*~

# Folio working state (drafts, snapshots)
.folio/
.tmp/

# folio inventory CLI の生成物 (REQ-VER-010、 generatedAt を含む作業用 output)。
# 検証の golden は tests/baselines/reference/ に track する。
inventory.json

# Claude Code session externalization (cc-session ready-compaction = .claude-session/)
.claude-session/
.mailbox/

# Playwright MCP の self-verify 生成物 (spec 図 render 確認時の snapshot/console log、 transient)
.playwright-mcp/

# spawn 先 git worktree
#   cc-session:spawn (現行) = .worktrees/ (隠しdir、 skill が対象 repo .gitignore に自動追記)
#   旧 session:spawn = worktrees/ (撤去済、 再生成防止に保持)
#   native claude --worktree = .claude/worktrees/
.worktrees/
worktrees/
.claude/worktrees/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
# Dolt が台帳の SSOT。jsonl export / embedded db は per-machine ゆえ track しない (beads-init #8)
.beads/issues.jsonl
.beads/interactions.jsonl
embeddeddolt/

# srs-ceiling-oracle 実行生成物 (dev-time・folio-mzn.1.5)
.claude-plugin/design-system/generator/oracle/out/
